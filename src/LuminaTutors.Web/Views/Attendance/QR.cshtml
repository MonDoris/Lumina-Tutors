@model LuminaTutors.Application.DTOs.Attendance.AttendanceSessionDto
@{
    Layout = null;
    ViewData["Title"] = "Mã QR Điểm danh";
    var expiresAt = Model?.QRExpiresAt ?? DateTime.UtcNow.AddMinutes(10);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
    <title>QR Điểm danh — @Model?.SubjectName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <link rel="stylesheet" href="~/css/lumina.css"/>
</head>
<body class="lt-qr-page">

<div class="lt-qr-panel">

    <div class="lt-qr-eyebrow">Lumina Tutors &mdash; Điểm danh QR</div>
    <h1 class="lt-qr-subject">@Model?.SubjectName</h1>
    <p class="lt-qr-meta">@Model?.ClassName &nbsp;&middot;&nbsp; @Model?.SessionDate.ToString("dd/MM/yyyy")</p>

    <!-- QR code -->
    <div class="lt-qr-canvas">
        <div id="qrCode"></div>
    </div>

    <!-- Countdown -->
    <div class="lt-qr-countdown-label">Thời gian còn lại</div>
    <div class="lt-qr-timer" id="timerDisplay">10:00</div>

    <!-- Live stats -->
    <div class="lt-qr-stats">
        <div>
            <div class="lt-qr-stat-val" id="statPresent">@Model?.PresentCount</div>
            <div class="lt-qr-stat-lbl">Đã điểm danh</div>
        </div>
        <div>
            <div class="lt-qr-stat-val">@Model?.TotalStudents</div>
            <div class="lt-qr-stat-lbl">Tổng học sinh</div>
        </div>
        <div>
            <div class="lt-qr-stat-val" id="statAbsent">@Model?.AbsentCount</div>
            <div class="lt-qr-stat-lbl">Chưa điểm danh</div>
        </div>
    </div>

    <p class="lt-qr-hint">Trang này tự động làm mới mỗi 15 giây</p>
</div>

<script>
// Generate QR code
const scanUrl = "@Url.Action("Scan", "Attendance", new { token = Model?.QRToken }, Context.Request.Scheme)";
new QRCode(document.getElementById("qrCode"), {
    text: scanUrl,
    width: 240,
    height: 240,
    colorDark:  "#0f1c2e",
    colorLight: "#ffffff",
    correctLevel: QRCode.CorrectLevel.H
});

// Countdown timer
const expiresAt = new Date("@expiresAt.ToString("o")");

function updateTimer() {
    const now  = new Date();
    const diff = Math.max(0, Math.floor((expiresAt - now) / 1000));
    const m    = String(Math.floor(diff / 60)).padStart(2, '0');
    const s    = String(diff % 60).padStart(2, '0');
    const el   = document.getElementById('timerDisplay');

    if (diff === 0) {
        el.textContent = 'Hết hạn';
        el.className = 'lt-qr-timer expiring';
        document.querySelector('.lt-qr-canvas').style.opacity = '.25';
        return;
    }

    el.textContent = `${m}:${s}`;
    el.className   = diff <= 60 ? 'lt-qr-timer expiring' : 'lt-qr-timer';
}

setInterval(updateTimer, 1000);
updateTimer();

// Auto-refresh stats every 15 s
setInterval(() => location.reload(), 15000);
</script>
</body>
</html>
