@using System.Security.Claims
@{
    ViewData["Title"] = "Dashboard";
    var fullName  = User.FindFirstValue(ClaimTypes.Name) ?? "Kế toán";
    var firstName = fullName.Split(' ').Last();
    var hour      = DateTime.Now.Hour;
    var greeting  = hour < 12 ? "Chào buổi sáng" : hour < 18 ? "Chào buổi chiều" : "Chào buổi tối";
    var today     = DateTime.Now.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"));
    var month     = DateTime.Now.ToString("MM/yyyy");
}

<!-- Banner -->
<div class="dash-banner dash-banner--accountant">
    <div class="dash-banner__grid"></div>
    <div class="dash-banner__left">
        <div class="dash-banner__eyebrow">
            <i class="bi bi-calculator-fill"></i>
            KẾ TOÁN
        </div>
        <div class="dash-banner__title">@greeting, @firstName 💼</div>
        <div class="dash-banner__sub">
            <i class="bi bi-calendar3"></i> @today
            <span style="opacity:.4">·</span>
            <i class="bi bi-currency-dollar"></i> Kỳ thu: Tháng @month
        </div>
    </div>
    <div class="dash-banner__right">
        <div class="dash-banner__icon-bg"><i class="bi bi-graph-up-arrow"></i></div>
    </div>
</div>

<!-- Stats Row -->
<div class="dash-stats dash-stats-4">
    <a href="/Finance/Invoices" class="dstat">
        <div class="dstat__icon dstat__icon--green"><i class="bi bi-cash-stack"></i></div>
        <div class="dstat__body">
            <div class="dstat__value">84.5tr</div>
            <div class="dstat__label">Đã thu tháng @month</div>
            <div class="dstat__trend dstat__trend--up"><i class="bi bi-arrow-up-short"></i> +8.2% tháng trước</div>
        </div>
    </a>
    <a href="/Finance/OutstandingDebts" class="dstat">
        <div class="dstat__icon dstat__icon--red"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <div class="dstat__body">
            <div class="dstat__value">12.3tr</div>
            <div class="dstat__label">Còn nợ chưa thu</div>
            <div class="dstat__trend dstat__trend--down"><i class="bi bi-arrow-down-short"></i> -15% tuần này</div>
        </div>
    </a>
    <a href="/Finance/Invoices" class="dstat">
        <div class="dstat__icon dstat__icon--amber"><i class="bi bi-receipt"></i></div>
        <div class="dstat__body">
            <div class="dstat__value">7</div>
            <div class="dstat__label">Hóa đơn quá hạn</div>
            <div class="dstat__trend dstat__trend--down"><i class="bi bi-arrow-down-short"></i> -3 so với tuần trước</div>
        </div>
    </a>
    <div class="dstat">
        <div class="dstat__icon dstat__icon--teal"><i class="bi bi-percent"></i></div>
        <div class="dstat__body">
            <div class="dstat__value">87.3%</div>
            <div class="dstat__label">Tỷ lệ thu học phí</div>
            <div class="dstat__trend dstat__trend--up"><i class="bi bi-arrow-up-short"></i> Mục tiêu: 95%</div>
        </div>
    </div>
</div>

<!-- Row 1: Revenue overview + Quick actions -->
<div class="dash-row dash-row-7-3">

    <div class="dcard">
        <div class="dcard__head">
            <div class="dcard__title"><i class="bi bi-bar-chart-fill" style="color:#0d9488"></i> Tổng quan tài chính tháng @month</div>
            <a href="/Finance" class="dcard__action">Báo cáo đầy đủ</a>
        </div>
        <div class="dcard__body">
            <!-- Summary metrics -->
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px">
                <div style="text-align:center;padding:14px;background:#f0fdfa;border-radius:12px;border:1px solid #99f6e4">
                    <div style="font-size:1.2rem;font-weight:800;color:#0d9488">84.5tr</div>
                    <div style="font-size:.72rem;color:#64748b;margin-top:3px">Đã thu</div>
                </div>
                <div style="text-align:center;padding:14px;background:#fef2f2;border-radius:12px;border:1px solid #fecaca">
                    <div style="font-size:1.2rem;font-weight:800;color:#dc2626">12.3tr</div>
                    <div style="font-size:.72rem;color:#64748b;margin-top:3px">Còn nợ</div>
                </div>
                <div style="text-align:center;padding:14px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0">
                    <div style="font-size:1.2rem;font-weight:800;color:#0f172a">96.8tr</div>
                    <div style="font-size:.72rem;color:#64748b;margin-top:3px">Kỳ vọng</div>
                </div>
            </div>

            <!-- Progress bar -->
            <div style="margin-bottom:6px;display:flex;justify-content:space-between">
                <span style="font-size:.78rem;font-weight:600;color:#64748b">Tiến độ thu học phí tháng @month</span>
                <span style="font-size:.8rem;font-weight:700;color:#0d9488">87.3%</span>
            </div>
            <div class="dash-progress" style="height:10px;margin-bottom:20px">
                <div class="dash-progress__bar" style="width:87.3%;background:linear-gradient(90deg,#0d9488,#2dd4bf)"></div>
            </div>

            <!-- By class breakdown -->
            <div style="font-size:.78rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">Chi tiết theo lớp</div>
            @{
                var classFinance = new[] {
                    new { Cls = "10A (28 HS)", Collected = 28, Total = 28, Pct = 100, Color = "#059669" },
                    new { Cls = "10B (30 HS)", Collected = 27, Total = 30, Pct = 90,  Color = "#059669" },
                    new { Cls = "11A (32 HS)", Collected = 25, Total = 32, Pct = 78,  Color = "#d97706" },
                    new { Cls = "12A (24 HS)", Collected = 19, Total = 24, Pct = 79,  Color = "#d97706" },
                    new { Cls = "12B (26 HS)", Collected = 15, Total = 26, Pct = 58,  Color = "#dc2626" },
                };
            }
            @foreach (var c in classFinance)
            {
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
                    <span style="font-size:.78rem;font-weight:600;color:#374151;width:120px;flex-shrink:0">@c.Cls</span>
                    <div style="flex:1">
                        <div class="dash-progress">
                            <div class="dash-progress__bar" style="width:@c.Pct%;background:@c.Color"></div>
                        </div>
                    </div>
                    <span style="font-size:.78rem;font-weight:700;color:@c.Color;width:40px;text-align:right;flex-shrink:0">@c.Pct%</span>
                    <span style="font-size:.72rem;color:#94a3b8;flex-shrink:0">@c.Collected/@c.Total</span>
                </div>
            }
        </div>
    </div>

    <div class="dcard">
        <div class="dcard__head">
            <div class="dcard__title"><i class="bi bi-lightning-fill" style="color:#0d9488"></i> Thao tác nhanh</div>
        </div>
        <div class="dcard__body">
            <div class="quick-actions">
                <a href="/Finance/Invoices/Create" class="qa-btn" style="--qa-color:#0d9488;--qa-bg:#f0fdfa">
                    <i class="bi bi-receipt"></i> Tạo hóa đơn mới
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>
                <a href="/Finance/OutstandingDebts" class="qa-btn" style="--qa-color:#dc2626;--qa-bg:#fef2f2">
                    <i class="bi bi-exclamation-triangle-fill"></i> Xem công nợ
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>
                <a href="/Finance/Invoices" class="qa-btn" style="--qa-color:#2563eb;--qa-bg:#eff6ff">
                    <i class="bi bi-list-check"></i> Danh sách hóa đơn
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>
                <a href="/Finance" class="qa-btn" style="--qa-color:#7c3aed;--qa-bg:#f5f3ff">
                    <i class="bi bi-graph-up-arrow"></i> Báo cáo tài chính
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>
            </div>
        </div>
    </div>

</div>

<!-- Row 2: Overdue invoices + Recent transactions -->
<div class="dash-row dash-row-5-5">

    <div class="dcard">
        <div class="dcard__head">
            <div class="dcard__title"><i class="bi bi-exclamation-triangle-fill" style="color:#dc2626"></i> Hóa đơn quá hạn</div>
            <a href="/Finance/OutstandingDebts" class="dcard__action">Xem tất cả</a>
        </div>
        <div class="dcard__body">
            @{
                var overdues = new[] {
                    new { Student = "Nguyễn Văn An",  Class = "12B", Amount = "2,400,000 đ", Days = 15, Severity = "high"   },
                    new { Student = "Trần Thị Bình",  Class = "11A", Amount = "2,400,000 đ", Days = 8,  Severity = "medium" },
                    new { Student = "Lê Hoàng Cường", Class = "12B", Amount = "4,800,000 đ", Days = 32, Severity = "high"   },
                    new { Student = "Phạm Thị Dung",  Class = "10B", Amount = "2,400,000 đ", Days = 3,  Severity = "low"    },
                };
            }
            <div style="display:flex;flex-direction:column;gap:8px">
                @foreach (var o in overdues)
                {
                    var borderColor = o.Severity == "high" ? "#fecaca" : o.Severity == "medium" ? "#fed7aa" : "#fde68a";
                    var bgColor     = o.Severity == "high" ? "#fef2f2" : o.Severity == "medium" ? "#fff7ed" : "#fffbeb";
                    var dayColor    = o.Severity == "high" ? "#dc2626" : o.Severity == "medium" ? "#c2410c" : "#d97706";
                    <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 14px;border-radius:10px;background:@bgColor;border:1px solid @borderColor">
                        <div>
                            <div style="font-size:.83rem;font-weight:700;color:#0f172a">@o.Student</div>
                            <div style="font-size:.75rem;color:#64748b">Lớp @o.Class · @o.Amount</div>
                        </div>
                        <div style="text-align:right">
                            <div style="font-size:.78rem;font-weight:700;color:@dayColor">Quá @o.Days ngày</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="dcard">
        <div class="dcard__head">
            <div class="dcard__title"><i class="bi bi-clock-history" style="color:#0d9488"></i> Giao dịch gần đây</div>
        </div>
        <div class="dcard__body">
            <div class="activity-list">
                @{
                    var txns = new[] {
                        new { Init = "NL", Bg = "#059669", Name = "Nguyễn Thị Lan",   Amount = "+2,400,000",  Note = "Thu học phí lớp 11A",      Time = "08:12" },
                        new { Init = "TH", Bg = "#059669", Name = "Trần Văn Hùng",    Amount = "+2,400,000",  Note = "Thu học phí lớp 10B",      Time = "08:35" },
                        new { Init = "PD", Bg = "#2563eb", Name = "Phạm Minh Đức",    Amount = "+4,800,000",  Note = "Thu 2 tháng lớp 12A",      Time = "09:10" },
                        new { Init = "LT", Bg = "#d97706", Name = "Lê Thị Thu",       Amount = "–",           Note = "Hoàn học phí (xin thôi học)",Time = "10:05"},
                    };
                }
                @foreach (var t in txns)
                {
                    <div class="activity-item">
                        <div class="activity-avatar" style="background:@t.Bg">@t.Init</div>
                        <div style="flex:1">
                            <div class="activity-text"><strong>@t.Name</strong> · @t.Note</div>
                            <div class="activity-time"><i class="bi bi-clock"></i> @t.Time hôm nay</div>
                        </div>
                        <div style="font-size:.83rem;font-weight:700;color:@(t.Amount.StartsWith("+") ? "#059669" : "#dc2626");flex-shrink:0">@t.Amount</div>
                    </div>
                }
            </div>
        </div>
    </div>

</div>
