@using System.Security.Claims
@using LuminaTutors.Application.DTOs.Account
@{
    ViewData["Title"] = "Dashboard";
    var role           = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var name           = User.FindFirstValue(ClaimTypes.Name) ?? "";
    var finance        = ViewBag.FinanceReport as LuminaTutors.Application.DTOs.Finance.MonthlyFinanceReportDto;
    var recentAccounts = ViewBag.RecentAccounts as List<AccountListItemDto>;
    var now            = DateTime.Now;
    var firstName      = name.Split(' ', StringSplitOptions.RemoveEmptyEntries).LastOrDefault() ?? name;
    var totalStudents  = (int)(ViewBag.TotalStudents ?? 0);
    var totalTeachers  = (int)(ViewBag.TotalTeachers ?? 0);
    var totalClasses   = (int)(ViewBag.TotalClasses  ?? 0);
    var activeYearName = (string)(ViewBag.ActiveYearName ?? "");
}

<!-- Greeting -->
<div class="lt-greeting">
    <div>
        <h1 class="lt-page-title">Chào mừng, @firstName</h1>
        <p class="lt-page-subtitle">
            @now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("vi-VN"))
            &nbsp;&middot;&nbsp;
            <span class="lt-badge lt-badge--navy">@role</span>
        </p>
    </div>
</div>

<!-- ── Stat Cards ── -->
<div class="row g-3 mb-4">

    @if (role is "ADMIN" or "TEACHER")
    {
        <div class="col-sm-6 col-xl-3">
            <a asp-controller="Account" asp-action="Index" asp-route-roleCode="STUDENT" style="text-decoration:none">
                <div class="lt-stat" data-testid="stat-students">
                    <div class="lt-stat__icon lt-stat__icon--navy">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div>
                        <div class="lt-stat__value">@totalStudents</div>
                        <div class="lt-stat__label">Học sinh</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a asp-controller="Class" asp-action="Index" style="text-decoration:none">
                <div class="lt-stat" data-testid="stat-classes">
                    <div class="lt-stat__icon lt-stat__icon--gold">
                        <i class="bi bi-building"></i>
                    </div>
                    <div>
                        <div class="lt-stat__value">@totalClasses</div>
                        <div class="lt-stat__label">
                            Lớp học
                            @if (!string.IsNullOrEmpty(activeYearName))
                            {
                                <small class="d-block" style="font-size:10px;opacity:.7">@activeYearName</small>
                            }
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-xl-3">
            <a asp-controller="Account" asp-action="Index" asp-route-roleCode="TEACHER" style="text-decoration:none">
                <div class="lt-stat" data-testid="stat-teachers">
                    <div class="lt-stat__icon lt-stat__icon--success">
                        <i class="bi bi-person-badge-fill"></i>
                    </div>
                    <div>
                        <div class="lt-stat__value">@totalTeachers</div>
                        <div class="lt-stat__label">Giáo viên</div>
                    </div>
                </div>
            </a>
        </div>
    }

    @if (role is "ACCOUNTANT" or "ADMIN")
    {
        <div class="col-sm-6 col-xl-3">
            <a asp-controller="Finance" asp-action="OutstandingDebts" style="text-decoration:none">
                <div class="lt-stat" data-testid="stat-debts">
                    <div class="lt-stat__icon lt-stat__icon--danger">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <div>
                        <div class="lt-stat__value">@(finance?.OverdueInvoices ?? 0)</div>
                        <div class="lt-stat__label">Hóa đơn quá hạn</div>
                    </div>
                </div>
            </a>
        </div>
    }

    @if (role == "SUPERVISOR")
    {
        <div class="col-sm-6 col-xl-3">
            <a asp-controller="Supervisor" asp-action="Records" style="text-decoration:none">
                <div class="lt-stat" data-testid="stat-discipline">
                    <div class="lt-stat__icon lt-stat__icon--danger">
                        <i class="bi bi-file-earmark-text-fill"></i>
                    </div>
                    <div>
                        <div class="lt-stat__value">—</div>
                        <div class="lt-stat__label">Vi phạm hôm nay</div>
                    </div>
                </div>
            </a>
        </div>
    }

    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Dashboard" asp-action="Notifications" style="text-decoration:none">
            <div class="lt-stat" data-testid="stat-notifications">
                <div class="lt-stat__icon lt-stat__icon--info">
                    <i class="bi bi-bell-fill"></i>
                </div>
                <div>
                    <div class="lt-stat__value">@(ViewBag.UnreadCount ?? 0)</div>
                    <div class="lt-stat__label">Thông báo chưa đọc</div>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- ── Finance + Quick Actions row ── -->
<div class="row g-4">

    @if (finance != null)
    {
    <div class="col-lg-8">
        <div class="lt-card">
            <div class="lt-card__header">
                <h3 class="lt-card__title">
                    <i class="bi bi-currency-dollar" style="color:var(--lt-gold);margin-right:6px"></i>
                    Tài chính tháng @now.Month/@now.Year
                </h3>
                <a asp-controller="Finance" asp-action="Index" class="lt-btn lt-btn--outline lt-btn--sm">
                    Chi tiết
                </a>
            </div>
            <div class="lt-card__body">

                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-3">
                        <div class="lt-metric">
                            <div class="lt-metric__value lt-metric__value--navy">
                                @finance.TotalBilled.ToString("N0")<span class="lt-metric__currency">đ</span>
                            </div>
                            <div class="lt-metric__label">Tổng phát sinh</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="lt-metric">
                            <div class="lt-metric__value lt-metric__value--success">
                                @finance.TotalCollected.ToString("N0")<span class="lt-metric__currency">đ</span>
                            </div>
                            <div class="lt-metric__label">Đã thu</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="lt-metric">
                            <div class="lt-metric__value lt-metric__value--danger">
                                @finance.TotalOutstanding.ToString("N0")<span class="lt-metric__currency">đ</span>
                            </div>
                            <div class="lt-metric__label">Còn lại</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="lt-metric">
                            <div class="lt-metric__value lt-metric__value--gold">
                                @finance.CollectionRate%
                            </div>
                            <div class="lt-metric__label">Tỷ lệ thu</div>
                        </div>
                    </div>
                </div>

                <!-- Collection progress -->
                <div class="lt-flex-between lt-text-xs lt-text-muted lt-mb-2">
                    <span>Tiến độ thu học phí</span>
                    <span>@finance.PaidInvoices / @finance.TotalInvoices hóa đơn</span>
                </div>
                <div class="lt-progress">
                    <div class="lt-progress__bar" style="width:@finance.CollectionRate%"></div>
                </div>

            </div>
        </div>
    </div>
    }

    <div class="@(finance != null ? "col-lg-4" : "col-12")">
        <div class="lt-card">
            <div class="lt-card__header">
                <h3 class="lt-card__title">Thao tác nhanh</h3>
            </div>
            <div class="lt-card__body lt-flex-col lt-gap-3">
                @if (role is "ADMIN" or "TEACHER")
                {
                    <a asp-controller="Attendance" asp-action="Index" class="lt-btn lt-btn--primary">
                        <i class="bi bi-qr-code-scan"></i> Mở điểm danh
                    </a>
                    <a asp-controller="Grading" asp-action="Index" class="lt-btn lt-btn--outline">
                        <i class="bi bi-journal-text"></i> Nhập điểm TT22
                    </a>
                }
                @if (role is "ACCOUNTANT" or "ADMIN")
                {
                    <a asp-controller="Finance" asp-action="Invoices" class="lt-btn lt-btn--outline">
                        <i class="bi bi-receipt"></i> Xem hóa đơn
                    </a>
                }
                @if (role == "SUPERVISOR")
                {
                    <a asp-controller="Supervisor" asp-action="Records" class="lt-btn lt-btn--outline">
                        <i class="bi bi-file-earmark-text"></i> Hồ sơ kỷ luật
                    </a>
                }
                @if (role == "ADMIN")
                {
                    <a asp-controller="Auth" asp-action="InviteLinks" class="lt-btn lt-btn--gold">
                        <i class="bi bi-link-45deg"></i> Tạo liên kết mời
                    </a>
                }
            </div>
        </div>
    </div>

</div>

@if (role == "ADMIN" && recentAccounts != null && recentAccounts.Count > 0)
{
<!-- ── Recent Accounts ── -->
<div class="row g-4 mt-1">
    <div class="col-12">
        <div class="lt-card">
            <div class="lt-card__header">
                <h3 class="lt-card__title">
                    <i class="bi bi-person-plus-fill" style="color:var(--lt-navy);margin-right:6px"></i>
                    Tài khoản mới nhất
                </h3>
                <a asp-controller="Account" asp-action="Index" class="lt-btn lt-btn--outline lt-btn--sm">
                    Xem tất cả
                </a>
            </div>
            <div class="lt-card__body p-0">
                <table class="table table-hover mb-0" style="font-size:.875rem">
                    <thead>
                        <tr style="background:var(--lt-surface-alt)">
                            <th class="ps-4 py-2" style="font-weight:600;color:var(--lt-text-muted);text-transform:uppercase;font-size:.7rem;letter-spacing:.05em">Họ tên</th>
                            <th class="py-2"       style="font-weight:600;color:var(--lt-text-muted);text-transform:uppercase;font-size:.7rem;letter-spacing:.05em">Vai trò</th>
                            <th class="py-2"       style="font-weight:600;color:var(--lt-text-muted);text-transform:uppercase;font-size:.7rem;letter-spacing:.05em">Email</th>
                            <th class="py-2 pe-4"  style="font-weight:600;color:var(--lt-text-muted);text-transform:uppercase;font-size:.7rem;letter-spacing:.05em">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var acc in recentAccounts)
                        {
                            <tr>
                                <td class="ps-4 py-2 align-middle">
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(acc.AvatarUrl))
                                        {
                                            <img src="@acc.AvatarUrl" alt="" class="rounded-circle" style="width:32px;height:32px;object-fit:cover">
                                        }
                                        else
                                        {
                                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                                 style="width:32px;height:32px;background:var(--lt-navy-light);color:var(--lt-navy);font-weight:700;font-size:.75rem;flex-shrink:0">
                                                @(acc.FullName.Split(' ').LastOrDefault()?.FirstOrDefault())
                                            </div>
                                        }
                                        <a asp-controller="Account" asp-action="Detail" asp-route-id="@acc.UserId"
                                           style="color:inherit;text-decoration:none;font-weight:500">@acc.FullName</a>
                                    </div>
                                </td>
                                <td class="py-2 align-middle">
                                    <span class="lt-badge @(acc.RoleCode == "TEACHER" ? "lt-badge--navy" : acc.RoleCode == "STUDENT" ? "lt-badge--gold" : "lt-badge--info")">
                                        @acc.RoleCode
                                    </span>
                                </td>
                                <td class="py-2 align-middle" style="color:var(--lt-text-muted)">@acc.Email</td>
                                <td class="py-2 pe-4 align-middle">
                                    @if (acc.IsActive)
                                    {
                                        <span class="lt-badge lt-badge--success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="lt-badge lt-badge--danger">Vô hiệu</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
}
