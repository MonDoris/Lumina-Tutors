@using System.Security.Claims
@{
    ViewData["Title"] = "Dashboard";
    var fullName  = User.FindFirstValue(ClaimTypes.Name) ?? "Giáo viên";
    var firstName = fullName.Split(' ').Last();
    var hour      = DateTime.Now.Hour;
    var greeting  = hour < 12 ? "Chào buổi sáng" : hour < 18 ? "Chào buổi chiều" : "Chào buổi tối";
    var today     = DateTime.Now.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"));

    // Gender-aware title: "Thầy" (Male) | "Cô" (Female/Other/null)
    var gender    = ViewBag.UserGender as string;
    var title     = gender == "Male" ? "Thầy" : "Cô";

    // Real data from controller
    var totalStudents = (int)(ViewBag.TotalStudents ?? 0);
    var totalClasses  = (int)(ViewBag.TotalClasses  ?? 0);
    var activeYear    = (string?)(ViewBag.ActiveYearName ?? "");
}

<!-- Banner -->
<div class="dash-banner dash-banner--teacher">
    <div class="dash-banner__grid"></div>
    <div class="dash-banner__left">
        <div class="dash-banner__eyebrow">
            <i class="bi bi-person-video3"></i>
            GIÁO VIÊN
        </div>
        <div class="dash-banner__title">@greeting, @title @firstName 👋</div>
        <div class="dash-banner__sub">
            <i class="bi bi-calendar3"></i> @today
            <span style="opacity:.4">·</span>
            <i class="bi bi-clock"></i> @DateTime.Now.ToString("HH:mm")
        </div>
    </div>
    <div class="dash-banner__right">
        <div class="dash-banner__icon-bg"><i class="bi bi-journal-bookmark-fill"></i></div>
    </div>
</div>

<!-- Stats Row -->
<div class="dash-stats dash-stats-4">
    <a href="/Class" class="dstat">
        <div class="dstat__icon dstat__icon--green"><i class="bi bi-building"></i></div>
        <div class="dstat__body">
            <div class="dstat__value">@totalClasses</div>
            <div class="dstat__label">Lớp trong trường</div>
            <div class="dstat__trend dstat__trend--neutral">
                <i class="bi bi-dash"></i>
                @(string.IsNullOrEmpty(activeYear) ? "Chưa có năm học" : activeYear)
            </div>
        </div>
    </a>
    <a href="/Student" class="dstat">
        <div class="dstat__icon dstat__icon--blue"><i class="bi bi-people-fill"></i></div>
        <div class="dstat__body">
            <div class="dstat__value">@totalStudents</div>
            <div class="dstat__label">Tổng học sinh</div>
            <div class="dstat__trend dstat__trend--neutral"><i class="bi bi-dash"></i> Toàn trường</div>
        </div>
    </a>
    <a href="/Attendance" class="dstat">
        <div class="dstat__icon dstat__icon--amber"><i class="bi bi-qr-code-scan"></i></div>
        <div class="dstat__body">
            <div class="dstat__value">—</div>
            <div class="dstat__label">Tỷ lệ chuyên cần TB</div>
            <div class="dstat__trend dstat__trend--neutral"><i class="bi bi-dash"></i> Chưa có dữ liệu</div>
        </div>
    </a>
    <a href="/Grading" class="dstat">
        <div class="dstat__icon dstat__icon--purple"><i class="bi bi-journal-text"></i></div>
        <div class="dstat__body">
            <div class="dstat__value">—</div>
            <div class="dstat__label">Cột điểm chưa nhập</div>
            <div class="dstat__trend dstat__trend--neutral"><i class="bi bi-dash"></i> Chưa có dữ liệu</div>
        </div>
    </a>
</div>

<!-- Row 1: Schedule + Attendance Ring -->
<div class="dash-row dash-row-7-3">

    <div class="dcard">
        <div class="dcard__head">
            <div class="dcard__title"><i class="bi bi-calendar-week-fill" style="color:#059669"></i> Lịch dạy hôm nay</div>
            <a href="/Class" class="dcard__action">Xem tất cả</a>
        </div>
        <div class="dcard__body">
            <div class="lt-empty lt-empty--sm" style="padding:2rem 0">
                <i class="bi bi-calendar2-x" style="font-size:2.2rem;color:#cbd5e1"></i>
                <div class="lt-empty__title" style="font-size:.9rem;margin-top:.5rem">Chưa có lịch dạy hôm nay</div>
                <div class="lt-empty__sub" style="font-size:.8rem">Lịch dạy sẽ hiển thị khi được phân công tiết dạy</div>
            </div>
        </div>
    </div>

    <div class="dcard">
        <div class="dcard__head">
            <div class="dcard__title"><i class="bi bi-graph-up-arrow" style="color:#059669"></i> Chuyên cần</div>
        </div>
        <div class="dcard__body">
            <div class="lt-empty lt-empty--sm" style="padding:2rem 0">
                <i class="bi bi-bar-chart" style="font-size:2.2rem;color:#cbd5e1"></i>
                <div class="lt-empty__title" style="font-size:.9rem;margin-top:.5rem">Chưa có dữ liệu</div>
                <div class="lt-empty__sub" style="font-size:.8rem">Dữ liệu chuyên cần sẽ hiển thị sau khi điểm danh</div>
            </div>
        </div>
    </div>

</div>

<!-- Row 2: Grade status + Quick actions -->
<div class="dash-row dash-row-6-4">

    <div class="dcard">
        <div class="dcard__head">
            <div class="dcard__title"><i class="bi bi-journal-text" style="color:#7c3aed"></i> Tình trạng sổ điểm TT22</div>
            <a href="/Grading" class="dcard__action">Cập nhật điểm</a>
        </div>
        <div class="dcard__body">
            <div class="lt-empty lt-empty--sm" style="padding:2rem 0">
                <i class="bi bi-journal-x" style="font-size:2.2rem;color:#cbd5e1"></i>
                <div class="lt-empty__title" style="font-size:.9rem;margin-top:.5rem">Chưa có dữ liệu điểm</div>
                <div class="lt-empty__sub" style="font-size:.8rem">Dữ liệu sẽ hiển thị khi có điểm số được nhập vào hệ thống</div>
            </div>
        </div>
    </div>

    <div class="dcard">
        <div class="dcard__head">
            <div class="dcard__title"><i class="bi bi-lightning-fill" style="color:#059669"></i> Thao tác nhanh</div>
        </div>
        <div class="dcard__body">
            <div class="quick-actions">
                <a href="/Attendance" class="qa-btn" style="--qa-color:#059669;--qa-bg:#ecfdf5">
                    <i class="bi bi-qr-code-scan"></i> Điểm danh QR
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>
                <a href="/Grading" class="qa-btn" style="--qa-color:#7c3aed;--qa-bg:#f5f3ff">
                    <i class="bi bi-pencil-fill"></i> Nhập điểm học sinh
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>
                <a href="/Student" class="qa-btn" style="--qa-color:#2563eb;--qa-bg:#eff6ff">
                    <i class="bi bi-person-lines-fill"></i> Danh sách học sinh
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>
                <a href="/Dashboard/Notifications" class="qa-btn" style="--qa-color:#d97706;--qa-bg:#fffbeb">
                    <i class="bi bi-bell-fill"></i> Xem thông báo
                    <i class="bi bi-chevron-right qa-arrow"></i>
                </a>
            </div>
        </div>
    </div>

</div>
