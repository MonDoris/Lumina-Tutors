@using LuminaTutors.Application.DTOs.Online
@using System.Web
@model JoinSessionResult
@{
    ViewData["Title"] = Model.Title;
    Layout = null;   // full-screen, no sidebar
    var userName  = ViewBag.UserName  as string ?? "Học sinh";
    var userEmail = ViewBag.UserEmail as string ?? "";
    var isTeacher = (ViewBag.Role as string ?? "") is "TEACHER" or "ADMIN";

    // Build Jitsi URL — all config via hash params so browser starts fetching immediately
    var jitsiConfig = string.Join("&",
        "config.startWithAudioMuted=true",
        "config.startWithVideoMuted=false",
        "config.prejoinPageEnabled=false",
        "config.disableDeepLinking=true",
        "config.enableWelcomePage=false",
        "config.defaultLanguage=vi",
        "config.disableInviteFunctions=true",
        "config.hideConferenceSubject=false",
        "config.toolbarButtons=[%22microphone%22%2C%22camera%22%2C%22desktop%22%2C%22fullscreen%22%2C%22hangup%22%2C%22chat%22%2C%22raisehand%22%2C%22tileview%22%2C%22videoquality%22%2C%22filmstrip%22]",
        $"userInfo.displayName={Uri.EscapeDataString(userName)}",
        $"userInfo.email={Uri.EscapeDataString(userEmail)}"
    );
    var jitsiSrc = $"https://meet.jit.si/{Model.JitsiRoom}#{jitsiConfig}";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@Model.Title — Phòng học Lumina</title>

    <!-- Pre-warm Jitsi connection AS EARLY AS POSSIBLE -->
    <link rel="preconnect" href="https://meet.jit.si" crossorigin>
    <link rel="preconnect" href="https://8x8.vc" crossorigin>
    <link rel="dns-prefetch" href="https://meet.jit.si">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --navy: #0f172a;
            --gold: #c9a96e;
            --muted:#64748b;
        }
        html, body { height:100%; font-family:'Inter',sans-serif; background:var(--navy); color:#f1f5f9; overflow:hidden; }

        /* ── Header ── */
        .room-header {
            height:50px; background:rgba(15,23,42,.97); border-bottom:1px solid rgba(201,169,110,.2);
            display:flex; align-items:center; padding:0 1rem; gap:10px; flex-shrink:0;
        }
        .room-logo  { font-size:.8rem; font-weight:700; color:var(--gold); }
        .room-title { flex:1; font-size:.88rem; font-weight:600; color:#f1f5f9;
                      white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .room-code  {
            font-family:monospace; font-size:.82rem; font-weight:700; color:var(--gold);
            background:rgba(201,169,110,.1); padding:3px 9px; border-radius:6px;
            border:1px solid rgba(201,169,110,.25); cursor:pointer; white-space:nowrap;
            user-select:none; transition:background .15s;
        }
        .room-code:hover { background:rgba(201,169,110,.22); }
        .live-badge {
            font-size:.68rem; font-weight:700; padding:2px 7px; border-radius:5px;
            background:rgba(239,68,68,.2); color:#fca5a5; border:1px solid rgba(239,68,68,.3);
            display:flex; align-items:center; gap:4px; white-space:nowrap;
        }
        .live-dot { width:6px; height:6px; border-radius:50%; background:#ef4444;
                    animation:pulse 1.2s ease-in-out infinite; }
        @@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.8)} }

        .btn { display:inline-flex; align-items:center; gap:5px; padding:.32rem .75rem;
               border-radius:7px; font-size:.78rem; font-weight:600; border:none; cursor:pointer;
               transition:all .15s; text-decoration:none; line-height:1.4; }
        .btn-danger  { background:rgba(220,38,38,.18); color:#fca5a5; border:1px solid rgba(220,38,38,.3); }
        .btn-danger:hover  { background:rgba(220,38,38,.32); }
        .btn-outline { background:transparent; color:#94a3b8; border:1px solid rgba(255,255,255,.15); }
        .btn-outline:hover { background:rgba(255,255,255,.08); color:#f1f5f9; }

        /* ── Body ── */
        .room-body { display:flex; height:calc(100vh - 50px); }

        /* ── Jitsi iframe wrapper ── */
        .jitsi-wrap { flex:1; position:relative; background:#0f172a; }

        /* Loading overlay — shown until iframe fires onload */
        #room-loading {
            position:absolute; inset:0; z-index:20;
            background:#0d1526;
            display:flex; flex-direction:column; align-items:center; justify-content:center; gap:14px;
            transition:opacity .35s ease;
        }
        #room-loading.gone { opacity:0; pointer-events:none; }
        .rl-ring {
            width:52px; height:52px; border-radius:50%;
            border:3px solid rgba(201,169,110,.15);
            border-top-color:var(--gold);
            animation:spin .85s linear infinite;
        }
        @@keyframes spin { to { transform:rotate(360deg); } }
        .rl-text { font-size:.82rem; color:#64748b; }
        .rl-bar  { width:180px; height:3px; background:rgba(255,255,255,.07); border-radius:99px; overflow:hidden; }
        .rl-fill { height:100%; background:linear-gradient(90deg,var(--gold),#e8c98a);
                   animation:fillBar 6s cubic-bezier(.4,0,.2,1) forwards; }
        @@keyframes fillBar {
            0%   { width:0% }
            30%  { width:55% }
            70%  { width:80% }
            100% { width:95% }   /* stops at 95% — jumps to 100% on load */
        }

        /* ── Jitsi iframe itself ── */
        #jitsi-frame {
            width:100%; height:100%; border:none; display:block;
            /* Render iframe immediately so browser can start fetching resources */
            visibility:visible;
        }

        /* ── Side panel ── */
        .room-side {
            width:240px; background:rgba(15,23,42,.9);
            border-left:1px solid rgba(255,255,255,.06);
            display:flex; flex-direction:column; flex-shrink:0;
        }
        .side-hdr { padding:.65rem .9rem; font-size:.72rem; font-weight:600; color:#475569;
                    text-transform:uppercase; letter-spacing:.05em;
                    border-bottom:1px solid rgba(255,255,255,.06); }
        .side-list { flex:1; overflow-y:auto; padding:.4rem; }
        .p-item { display:flex; align-items:center; gap:8px; padding:.4rem .5rem;
                  border-radius:7px; margin-bottom:2px; }
        .p-item:hover { background:rgba(255,255,255,.05); }
        .p-ava  { width:26px; height:26px; border-radius:6px; background:rgba(201,169,110,.18);
                  color:var(--gold); font-size:.68rem; font-weight:700; flex-shrink:0;
                  display:flex; align-items:center; justify-content:center; }
        .p-name { font-size:.78rem; color:#cbd5e1; flex:1; overflow:hidden;
                  text-overflow:ellipsis; white-space:nowrap; }
        .p-role { font-size:.62rem; color:#475569; }
        .side-tip { padding:.7rem .9rem; border-top:1px solid rgba(255,255,255,.06);
                    font-size:.7rem; color:#475569; text-align:center; line-height:1.5; }

        /* ── Copy toast ── */
        #toast {
            position:fixed; bottom:18px; left:50%; transform:translateX(-50%);
            background:rgba(15,23,42,.95); color:#f1f5f9; font-size:.78rem;
            padding:.45rem 1.1rem; border-radius:8px; border:1px solid rgba(201,169,110,.3);
            opacity:0; pointer-events:none; transition:opacity .22s; z-index:999;
        }
        #toast.show { opacity:1; }

        @@media (max-width:768px) { .room-side { display:none; } }
    </style>
</head>
<body>

<header class="room-header">
    <span class="room-logo"><i class="bi bi-mortarboard-fill"></i> Lumina</span>
    <div class="room-title">@Model.Title</div>

    @if (Model.Status == "Live")
    {
        <span class="live-badge"><span class="live-dot"></span>LIVE</span>
    }

    <span class="room-code" onclick="copyCode('@Model.RoomCode')" title="Nhấn để sao chép">
        <i class="bi bi-key-fill" style="font-size:.72rem"></i> @Model.RoomCode
    </span>

    @if (isTeacher)
    {
        <form asp-controller="OnlineClass" asp-action="End" asp-route-id="@Model.SessionId" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger"
                    onclick="return confirm('Kết thúc buổi học cho tất cả?')">
                <i class="bi bi-stop-fill"></i> Kết thúc
            </button>
        </form>
    }
    else
    {
        <form asp-controller="OnlineClass" asp-action="Leave" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="sessionId" value="@Model.SessionId"/>
            <button type="submit" class="btn btn-outline">
                <i class="bi bi-box-arrow-right"></i> Rời phòng
            </button>
        </form>
    }
</header>

<div class="room-body">

    <div class="jitsi-wrap">
        <!-- Loading overlay — disappears when iframe finishes loading -->
        <div id="room-loading">
            <div class="rl-ring"></div>
            <div class="rl-bar"><div class="rl-fill" id="rl-fill"></div></div>
            <div class="rl-text" id="rl-text">Đang kết nối phòng học...</div>
        </div>

        <!--
            DIRECT IFRAME — browser starts fetching Jitsi resources
            the instant it parses this tag, without waiting for any JS.
            Config is passed via URL hash so no round-trip is needed.
        -->
        <iframe
            id="jitsi-frame"
            src="@jitsiSrc"
            allow="camera; microphone; fullscreen; display-capture; clipboard-write; autoplay"
            allowfullscreen
            loading="eager"
            onload="frameLoaded()">
        </iframe>
    </div>

    <!-- Participants panel -->
    <aside class="room-side">
        <div class="side-hdr">
            <i class="bi bi-people-fill" style="margin-right:4px"></i>
            Tham gia (<span id="pCount">—</span>)
        </div>
        <div class="side-list" id="pList">
            <div style="padding:1rem;text-align:center;font-size:.75rem;color:#475569">Đang tải...</div>
        </div>
        <div class="side-tip">
            <i class="bi bi-chat-dots-fill" style="color:var(--gold)"></i>
            Dùng <strong style="color:#94a3b8">Chat</strong> trong video để nhắn tin lớp
        </div>
    </aside>
</div>

<div id="toast"><i class="bi bi-check2-circle" style="color:var(--gold)"></i> Đã sao chép mã phòng</div>

<script>
const SESSION_ID = @Model.SessionId;

// ── Loading overlay ────────────────────────────────────────────────────────
function frameLoaded() {
    const overlay = document.getElementById('room-loading');
    if (!overlay) return;
    // Snap bar to 100% then fade overlay
    const fill = document.getElementById('rl-fill');
    fill.style.animation = 'none';
    fill.style.width      = '100%';
    fill.style.transition = 'width .25s ease';

    document.getElementById('rl-text').textContent = 'Đã kết nối!';

    setTimeout(() => {
        overlay.classList.add('gone');
        setTimeout(() => overlay.remove(), 380);
    }, 260);
}

// Safety: if onload never fires (CSP, redirect) remove overlay after 8s
setTimeout(frameLoaded, 8000);

// ── Participants panel ─────────────────────────────────────────────────────
async function loadParticipants() {
    try {
        const r = await fetch(`/OnlineClass/Participants/${SESSION_ID}`);
        if (!r.ok) return;
        const data = await r.json();
        const active = data.filter(p => !p.leftAt);

        document.getElementById('pCount').textContent = active.length;

        const list = document.getElementById('pList');
        if (!active.length) {
            list.innerHTML = '<div style="padding:1rem;text-align:center;font-size:.75rem;color:#475569">Chưa có người tham gia</div>';
            return;
        }

        list.innerHTML = active.map(p => {
            const ini = p.fullName.split(' ').slice(-2).map(w => w[0]).join('');
            return `<div class="p-item">
                <div class="p-ava">${esc(ini)}</div>
                <div class="p-name">${esc(p.fullName)}</div>
                <div class="p-role">${p.role === 'TEACHER' || p.role === 'ADMIN' ? 'GV' : 'HS'}</div>
            </div>`;
        }).join('');
    } catch { /* silent */ }
}

function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

loadParticipants();
setInterval(loadParticipants, 12_000);

// ── Copy code ──────────────────────────────────────────────────────────────
function copyCode(code) {
    navigator.clipboard?.writeText(code).then(() => {
        const t = document.getElementById('toast');
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 2000);
    });
}

// ── Record leave when navigating away ─────────────────────────────────────
const _afToken = document.querySelector('input[name=__RequestVerificationToken]')?.value ?? '';
function recordLeave() {
    navigator.sendBeacon('/OnlineClass/Leave',
        new URLSearchParams({ sessionId: SESSION_ID, __RequestVerificationToken: _afToken }));
}
window.addEventListener('pagehide',     recordLeave);
window.addEventListener('beforeunload', recordLeave);
</script>

<!-- Hidden AF token for JS beacon -->
<form style="display:none">@Html.AntiForgeryToken()</form>
</body>
</html>
