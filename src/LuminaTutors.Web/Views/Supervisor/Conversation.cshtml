@using LuminaTutors.Domain.Common
@using LuminaTutors.Application.DTOs.Communication
@model PagedResult<MessageDto>
@{
    ViewData["Title"] = "Hội thoại";
    var conversationId = ViewBag.ConversationId as int? ?? 0;
}

<div class="lt-page-header">
    <div>
        <a asp-action="Messages" class="lt-btn lt-btn--outline lt-btn--sm lt-mb-3">
            <i class="bi bi-arrow-left"></i> Danh sách hội thoại
        </a>
        <h1 class="lt-page-title">Hội thoại</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="lt-card" style="display:flex;flex-direction:column;height:calc(100vh - 260px);min-height:400px">
            <!-- Messages area -->
            <div id="msg-area" style="flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:12px">
                @if (Model?.Items?.Any() != true)
                {
                    <div class="lt-empty" style="margin:auto">
                        <div class="lt-empty__icon"><i class="bi bi-chat-dots"></i></div>
                        <p class="lt-empty__title">Chưa có tin nhắn</p>
                        <p class="lt-empty__text">Hãy bắt đầu cuộc trò chuyện!</p>
                    </div>
                }
                else
                {
                    @foreach (var msg in Model.Items.OrderBy(m => m.SentAt))
                    {
                        var isMine = msg.IsMine;
                        <div style="display:flex;flex-direction:column;align-items:@(isMine ? "flex-end" : "flex-start");gap:4px">
                            @if (!isMine)
                            {
                                <span class="lt-text-xs lt-text-muted">@msg.SenderName</span>
                            }
                            @if (!msg.IsDeleted && msg.MessageText != null)
                            {
                                <div style="max-width:70%;padding:10px 14px;border-radius:12px;
                                            background:@(isMine ? "var(--lt-navy)" : "var(--lt-ivory)");
                                            color:@(isMine ? "#fff" : "var(--lt-text)");
                                            border:1px solid @(isMine ? "transparent" : "var(--lt-border)");
                                            border-bottom-@(isMine ? "right" : "left")-radius:3px">
                                    <span style="font-size:.88rem;line-height:1.5">@msg.MessageText</span>
                                </div>
                            }
                            else if (msg.IsDeleted)
                            {
                                <div style="max-width:70%;padding:8px 14px;border-radius:12px;
                                            background:var(--lt-border-light);color:var(--lt-text-muted);
                                            font-style:italic;font-size:.8rem">
                                    Tin nhắn đã bị xóa
                                </div>
                            }
                            @if (msg.AttachmentUrl != null)
                            {
                                <div style="max-width:70%">
                                    <a href="@msg.AttachmentUrl" target="_blank"
                                       class="lt-btn lt-btn--outline lt-btn--sm">
                                        <i class="bi bi-paperclip"></i> Tệp đính kèm
                                    </a>
                                </div>
                            }
                            <span class="lt-text-xs lt-text-muted">@msg.SentAt.ToString("HH:mm dd/MM")</span>
                        </div>
                    }
                }
            </div>

            <!-- Pagination -->
            @if (Model?.HasPreviousPage == true)
            {
                <div style="padding:8px 20px;border-top:1px solid var(--lt-border-light);text-align:center">
                    <a asp-action="Conversation"
                       asp-route-id="@conversationId"
                       asp-route-page="@(Model.PageNumber - 1)"
                       class="lt-btn lt-btn--outline lt-btn--sm">
                        <i class="bi bi-arrow-up"></i> Tải tin nhắn cũ hơn
                    </a>
                </div>
            }

            <!-- Send message form -->
            <div style="padding:16px 20px;border-top:1px solid var(--lt-border)">
                <form asp-action="SendMessage" method="post" id="send-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ConversationId" value="@conversationId"/>
                    <div style="display:flex;gap:10px;align-items:flex-end">
                        <textarea name="MessageText" class="lt-input"
                                  placeholder="Nhập tin nhắn..."
                                  rows="2"
                                  style="flex:1;resize:none;min-height:42px;max-height:120px"
                                  data-testid="input-message"
                                  required></textarea>
                        <button type="submit" class="lt-btn lt-btn--primary" style="height:42px;flex-shrink:0"
                                data-testid="btn-send">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Auto-scroll to bottom on load
    (function () {
        var area = document.getElementById('msg-area');
        if (area) area.scrollTop = area.scrollHeight;
    })();

    // Allow Ctrl+Enter to submit
    document.querySelector('textarea[name="MessageText"]')?.addEventListener('keydown', function (e) {
        if (e.ctrlKey && e.key === 'Enter') {
            document.getElementById('send-form').submit();
        }
    });
</script>
}
