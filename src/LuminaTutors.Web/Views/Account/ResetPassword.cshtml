@using LuminaTutors.Application.DTOs.Account
@model AdminResetPasswordRequest
@{
    var acc = (AccountDetailDto)ViewBag.Account;
    ViewData["Title"] = $"Đặt lại mật khẩu — {acc.FullName}";
    var initials = acc.FullName.Length > 0
        ? string.Concat(acc.FullName.Split(' ').TakeLast(2).Select(p => p[0]))
        : "?";
}

<div style="max-width:480px;margin:40px auto">

    <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
        <a asp-action="Detail" asp-route-id="@acc.UserId" style="width:36px;height:36px;border-radius:10px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;color:#64748b;text-decoration:none">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h2 style="font-size:1.1rem;font-weight:800;color:#0f172a;margin:0">Đặt lại mật khẩu</h2>
            <p style="font-size:.82rem;color:#94a3b8;margin:0">@acc.FullName · @acc.Email</p>
        </div>
    </div>

    <div class="dcard">
        <div class="dcard__head">
            <div class="dcard__title"><i class="bi bi-key-fill" style="color:#d97706"></i> Mật khẩu mới</div>
        </div>
        <div class="dcard__body">
            <!-- Warning banner -->
            <div style="display:flex;align-items:flex-start;gap:10px;background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:12px 14px;margin-bottom:20px">
                <i class="bi bi-exclamation-triangle-fill" style="color:#d97706;flex-shrink:0;margin-top:1px"></i>
                <div style="font-size:.82rem;color:#92400e">
                    Hành động này sẽ thay thế mật khẩu hiện tại của <strong>@acc.FullName</strong>.
                    Hãy thông báo cho họ biết mật khẩu mới sau khi đặt.
                </div>
            </div>

            <form asp-action="ResetPassword" asp-route-id="@acc.UserId" method="post">
                @Html.AntiForgeryToken()
                <div style="margin-bottom:14px">
                    <label class="lt-form__label">Mật khẩu mới <span style="color:#dc2626">*</span></label>
                    <input asp-for="NewPassword" type="password" class="lt-form__input" placeholder="Tối thiểu 8 ký tự" autocomplete="new-password"/>
                    <span asp-validation-for="NewPassword" class="text-danger" style="font-size:.78rem"></span>
                </div>
                <div style="margin-bottom:20px">
                    <label class="lt-form__label">Xác nhận mật khẩu <span style="color:#dc2626">*</span></label>
                    <input asp-for="ConfirmPassword" type="password" class="lt-form__input" placeholder="Nhập lại mật khẩu" autocomplete="new-password"/>
                    <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:.78rem"></span>
                </div>

                <div asp-validation-summary="ModelOnly" class="lt-alert lt-alert--danger" style="margin-bottom:14px"></div>

                <div style="display:flex;gap:10px">
                    <a asp-action="Detail" asp-route-id="@acc.UserId" style="flex:1;text-align:center;padding:11px;border:1.5px solid #e2e8f0;border-radius:10px;color:#64748b;font-size:.875rem;font-weight:600;text-decoration:none">Hủy</a>
                    <button type="submit" style="flex:1;padding:11px;border-radius:10px;background:#d97706;color:#fff;font-size:.875rem;font-weight:700;border:none;cursor:pointer">
                        <i class="bi bi-key-fill"></i> Đặt lại mật khẩu
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>
