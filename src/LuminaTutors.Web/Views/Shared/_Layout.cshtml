@using System.Security.Claims
@{
    var isAuth   = User.Identity?.IsAuthenticated == true;
    var fullName = User.FindFirstValue(ClaimTypes.Name) ?? "";
    var roleCode = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var school   = User.FindFirstValue("SchoolName") ?? "Lumina Tutors";
    var avatarUrl = User.FindFirstValue("AvatarUrl");
    var initials = fullName.Length > 0 ? string.Concat(fullName.Split(' ').TakeLast(2).Select(p => p[0])) : "LT";

    string Nav(string ctrl, string? action = "Index")
        => Context.Request.Path.StartsWithSegments($"/{ctrl}", StringComparison.OrdinalIgnoreCase)
            ? "lt-nav__item active"
            : "lt-nav__item";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="description" content="Lumina Tutors — Hệ thống quản lý giáo dục">
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — Lumina Tutors" : "Lumina Tutors")</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- Lumina Luxury Theme -->
    <link rel="stylesheet" href="~/css/lumina.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true"/>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

@if (isAuth)
{
<div class="lt-app">

    <!-- ══════════ SIDEBAR ══════════ -->
    <aside class="lt-sidebar" id="ltSidebar" aria-label="Điều hướng chính">

        <!-- Brand -->
        <div class="lt-sidebar__brand">
            <div class="lt-sidebar__brand-logo">
                <div class="lt-sidebar__brand-icon">L</div>
                <div>
                    <div class="lt-sidebar__brand-name">Lumina Tutors</div>
                    <div class="lt-sidebar__brand-sub">@school</div>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="lt-nav" role="navigation">

            <!-- Core -->
            <div class="lt-nav__section">
                <div class="lt-nav__section-label">Tổng quan</div>
                <a asp-controller="Dashboard" asp-action="Index" class="@Nav("Dashboard")">
                    <span class="lt-nav__icon"><i class="bi bi-grid-1x2-fill"></i></span>
                    Dashboard
                </a>
                <a asp-controller="Dashboard" asp-action="Notifications" class="@Nav("Dashboard", "Notifications")">
                    <span class="lt-nav__icon"><i class="bi bi-bell-fill"></i></span>
                    Thông báo
                    @if ((ViewBag.UnreadCount as int?) > 0)
                    {
                        <span class="lt-nav__badge">@ViewBag.UnreadCount</span>
                    }
                </a>
            </div>

            <!-- Academic -->
            @if (roleCode is "ADMIN" or "TEACHER")
            {
            <div class="lt-nav__section">
                <div class="lt-nav__section-label">Học vụ</div>
                <a asp-controller="Class" asp-action="Index" class="@Nav("Class")">
                    <span class="lt-nav__icon"><i class="bi bi-building"></i></span>
                    Lớp học
                </a>
                <a asp-controller="Student" asp-action="Index" class="@Nav("Student")">
                    <span class="lt-nav__icon"><i class="bi bi-people-fill"></i></span>
                    Học sinh
                </a>
                <a asp-controller="Attendance" asp-action="Index" class="@Nav("Attendance")">
                    <span class="lt-nav__icon"><i class="bi bi-qr-code-scan"></i></span>
                    Điểm danh QR
                </a>
                <a asp-controller="Grading" asp-action="Index" class="@Nav("Grading")">
                    <span class="lt-nav__icon"><i class="bi bi-journal-text"></i></span>
                    Sổ điểm TT22
                </a>
            </div>
            }

            <!-- Finance (Accountant + Admin) -->
            @if (roleCode is "ACCOUNTANT" or "ADMIN")
            {
            <div class="lt-nav__section">
                <div class="lt-nav__section-label">Tài chính</div>
                <a asp-controller="Finance" asp-action="Index" class="@Nav("Finance")">
                    <span class="lt-nav__icon"><i class="bi bi-currency-dollar"></i></span>
                    Tổng quan
                </a>
                <a asp-controller="Finance" asp-action="Invoices" class="@Nav("Finance", "Invoices")">
                    <span class="lt-nav__icon"><i class="bi bi-receipt"></i></span>
                    Hóa đơn học phí
                </a>
                <a asp-controller="Finance" asp-action="OutstandingDebts" class="@Nav("Finance", "OutstandingDebts")">
                    <span class="lt-nav__icon"><i class="bi bi-exclamation-triangle-fill"></i></span>
                    Công nợ
                </a>
            </div>
            }

            <!-- HR (Admin only) -->
            @if (roleCode == "ADMIN")
            {
            <div class="lt-nav__section">
                <div class="lt-nav__section-label">Nhân sự</div>
                <a href="/HR/Teachers" class="@Nav("HR")">
                    <span class="lt-nav__icon"><i class="bi bi-person-badge-fill"></i></span>
                    Giáo viên
                </a>
                <a asp-controller="Auth" asp-action="InviteLinks" class="@Nav("Auth", "InviteLinks")">
                    <span class="lt-nav__icon"><i class="bi bi-link-45deg"></i></span>
                    Liên kết mời
                </a>
            </div>
            }

            <!-- Supervisor -->
            @if (roleCode is "SUPERVISOR" or "ADMIN")
            {
            <div class="lt-nav__section">
                <div class="lt-nav__section-label">Giám thị</div>
                <a asp-controller="Supervisor" asp-action="Index" class="@Nav("Supervisor")">
                    <span class="lt-nav__icon"><i class="bi bi-shield-fill"></i></span>
                    Tổng quan
                </a>
                <a asp-controller="Supervisor" asp-action="Records" class="@Nav("Supervisor", "Records")">
                    <span class="lt-nav__icon"><i class="bi bi-file-earmark-text-fill"></i></span>
                    Hồ sơ kỷ luật
                </a>
                <a asp-controller="Supervisor" asp-action="Messages" class="@Nav("Supervisor", "Messages")">
                    <span class="lt-nav__icon"><i class="bi bi-chat-dots-fill"></i></span>
                    Nhắn tin PH
                </a>
            </div>
            }

        </nav>

        <!-- Sidebar Footer — User -->
        <div class="lt-sidebar__footer">
            <div class="lt-sidebar__user">
                <div class="lt-sidebar__avatar">
                    @if (!string.IsNullOrEmpty(avatarUrl))
                    {
                        <img src="@avatarUrl" alt="Avatar">
                    }
                    else
                    {
                        @initials
                    }
                </div>
                <div class="lt-flex-1">
                    <div class="lt-sidebar__user-name">@fullName</div>
                    <div class="lt-sidebar__user-role">@roleCode</div>
                </div>
                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="lt-topbar__btn" title="Đăng xuất">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <!-- ══════════ MAIN ══════════ -->
    <div class="lt-main">

        <!-- Topbar -->
        <header class="lt-topbar">
            <!-- Mobile hamburger -->
            <button class="lt-topbar__btn d-lg-none" id="sidebarToggle" aria-label="Mở menu">
                <i class="bi bi-list" style="font-size:1.3rem"></i>
            </button>

            <h1 class="lt-topbar__title">@(ViewData["Title"] ?? "Dashboard")</h1>

            <div class="lt-topbar__actions">
                <!-- Notification bell -->
                <a asp-controller="Dashboard" asp-action="Notifications" class="lt-topbar__btn" title="Thông báo">
                    <i class="bi bi-bell"></i>
                    @if ((ViewBag.UnreadCount as int?) > 0)
                    {
                        <span class="lt-topbar__notif-dot"></span>
                    }
                </a>

                <!-- Change password -->
                <a asp-controller="Auth" asp-action="ChangePassword" class="lt-topbar__btn" title="Đổi mật khẩu">
                    <i class="bi bi-key"></i>
                </a>
            </div>
        </header>

        <!-- Alerts (TempData) -->
        @if (TempData["Success"] != null || TempData["Error"] != null)
        {
            <div style="padding:20px 32px 0">
                @if (TempData["Success"] != null)
                {
                    <div class="lt-alert lt-alert--success" role="alert" data-testid="alert-success">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@TempData["Success"]</span>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="lt-alert lt-alert--danger" role="alert" data-testid="alert-error">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <span>@TempData["Error"]</span>
                    </div>
                }
            </div>
        }

        <!-- Page Content -->
        <main class="lt-content" id="mainContent">
            @RenderBody()
        </main>

    </div><!-- /.lt-main -->

</div><!-- /.lt-app -->
}
else
{
    <!-- Unauthenticated pages (Login, Activate) render full-width -->
    @RenderBody()
}

<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
// Sidebar toggle (mobile)
const sidebarToggle = document.getElementById('sidebarToggle');
const ltSidebar     = document.getElementById('ltSidebar');
if (sidebarToggle && ltSidebar) {
    sidebarToggle.addEventListener('click', () => ltSidebar.classList.toggle('open'));
    document.addEventListener('click', e => {
        if (!ltSidebar.contains(e.target) && !sidebarToggle.contains(e.target))
            ltSidebar.classList.remove('open');
    });
}

// Auto-dismiss alerts after 5 s
document.querySelectorAll('.lt-alert').forEach(el => {
    setTimeout(() => {
        el.style.transition = 'opacity .5s';
        el.style.opacity = '0';
        setTimeout(() => el.remove(), 500);
    }, 5000);
});
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
