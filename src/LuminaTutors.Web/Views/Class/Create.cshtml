@using LuminaTutors.Application.DTOs.Class
@model CreateClassRequest
@{
    ViewData["Title"] = "Tạo lớp học mới";
    var teachers = ViewBag.Teachers as List<TeacherSummaryDto> ?? new List<TeacherSummaryDto>();
    var academicYearId = ViewBag.AcademicYearId as int? ?? 1;
}

<div class="lt-page-header">
    <div>
        <a asp-action="Index" asp-route-academicYearId="@academicYearId"
           class="lt-btn lt-btn--outline lt-btn--sm lt-mb-3">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <h1 class="lt-page-title">Tạo lớp học mới</h1>
        <p class="lt-page-subtitle">Điền thông tin để tạo lớp học cho năm học hiện tại</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="lt-card">
            <div class="lt-card__header">
                <h3 class="lt-card__title">Thông tin lớp học</h3>
            </div>
            <div class="lt-card__body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="AcademicYearId" value="@academicYearId"/>

                    <div class="lt-form-group">
                        <label class="lt-label" asp-for="ClassName">
                            Tên lớp <span class="lt-text-danger">*</span>
                        </label>
                        <input asp-for="ClassName" class="lt-input"
                               placeholder="VD: 10A1" required data-testid="input-class-name"/>
                        <span asp-validation-for="ClassName" class="lt-form-error"></span>
                    </div>

                    <div class="lt-form-group">
                        <label class="lt-label">ID Khối lớp <span class="lt-text-danger">*</span></label>
                        <input type="number" name="GradeLevelId" class="lt-input"
                               placeholder="VD: 1" required/>
                    </div>

                    <div class="lt-form-group">
                        <label class="lt-label" asp-for="HomeRoomTeacherId">Giáo viên chủ nhiệm</label>
                        <select asp-for="HomeRoomTeacherId" class="lt-select">
                            <option value="">— Chưa phân công —</option>
                            @foreach (var t in teachers)
                            {
                                <option value="@t.UserId">@t.FullName (@t.TeacherCode)</option>
                            }
                        </select>
                    </div>

                    <div class="lt-form-group">
                        <label class="lt-label" asp-for="MaxStudents">Sĩ số tối đa</label>
                        <input asp-for="MaxStudents" type="number" class="lt-input"
                               min="1" max="60" value="40"/>
                        <span asp-validation-for="MaxStudents" class="lt-form-error"></span>
                    </div>

                    <div class="lt-form-group lt-mb-4">
                        <label class="lt-label" asp-for="RoomNumber">Phòng học</label>
                        <input asp-for="RoomNumber" class="lt-input" placeholder="VD: A101"/>
                    </div>

                    <div class="lt-flex-between">
                        <a asp-action="Index" asp-route-academicYearId="@academicYearId"
                           class="lt-btn lt-btn--outline">Hủy</a>
                        <button type="submit" class="lt-btn lt-btn--primary" data-testid="btn-submit-class">
                            <i class="bi bi-check-lg"></i> Tạo lớp học
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}
