@using LuminaTutors.Application.DTOs.Class
@model CreateClassRequest
@{
    ViewData["Title"] = "Tạo lớp học mới";
    var teachers      = ViewBag.Teachers      as List<TeacherSummaryDto>      ?? new List<TeacherSummaryDto>();
    var gradeLevels   = ViewBag.GradeLevels   as List<GradeLevelSelectDto>    ?? new List<GradeLevelSelectDto>();
    var academicYears = ViewBag.AcademicYears as List<AcademicYearSelectDto>  ?? new List<AcademicYearSelectDto>();
}

<div class="lt-page-header">
    <div>
        <a asp-action="Index" asp-route-academicYearId="@(Model?.AcademicYearId)"
           class="lt-btn lt-btn--outline lt-btn--sm lt-mb-3">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <h1 class="lt-page-title">Tạo lớp học mới</h1>
        <p class="lt-page-subtitle">Điền thông tin để tạo lớp học mới</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="lt-card">
            <div class="lt-card__header">
                <h3 class="lt-card__title">
                    <i class="bi bi-building" style="color:var(--lt-navy);margin-right:6px"></i>
                    Thông tin lớp học
                </h3>
            </div>
            <div class="lt-card__body">
                @if (!ViewContext.ModelState.IsValid)
                {
                    <div class="lt-alert lt-alert--danger lt-mb-4">
                        @foreach (var err in ViewContext.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@err.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Tên lớp -->
                    <div class="lt-form-group">
                        <label class="lt-label" asp-for="ClassName">
                            Tên lớp <span class="lt-text-danger">*</span>
                        </label>
                        <input asp-for="ClassName" class="lt-input"
                               placeholder="VD: 10A1, 11B2..." required data-testid="input-class-name"/>
                        <span asp-validation-for="ClassName" class="lt-form-error"></span>
                    </div>

                    <!-- Năm học -->
                    <div class="lt-form-group">
                        <label class="lt-label" asp-for="AcademicYearId">
                            Năm học <span class="lt-text-danger">*</span>
                        </label>
                        @if (academicYears.Any())
                        {
                            <select asp-for="AcademicYearId" class="lt-select" required>
                                <option value="0">— Chọn năm học —</option>
                                @foreach (var ay in academicYears)
                                {
                                    <option value="@ay.AcademicYearId">
                                        @ay.YearName @(ay.IsActive ? "(Hiện tại)" : "")
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="AcademicYearId" class="lt-form-error"></span>
                        }
                        else
                        {
                            <div class="lt-alert lt-alert--warning" style="padding:8px 12px;border-radius:8px;font-size:.85rem">
                                <i class="bi bi-exclamation-triangle"></i>
                                Chưa có năm học nào. Vui lòng tạo năm học trước.
                            </div>
                            <input asp-for="AcademicYearId" type="hidden" value="0"/>
                        }
                    </div>

                    <!-- Khối lớp -->
                    <div class="lt-form-group">
                        <label class="lt-label" asp-for="GradeLevelId">
                            Khối lớp <span class="lt-text-danger">*</span>
                        </label>
                        @if (gradeLevels.Any())
                        {
                            <select asp-for="GradeLevelId" class="lt-select" required>
                                <option value="0">— Chọn khối lớp —</option>
                                @foreach (var gl in gradeLevels)
                                {
                                    <option value="@gl.GradeLevelId">@gl.GradeName</option>
                                }
                            </select>
                            <span asp-validation-for="GradeLevelId" class="lt-form-error"></span>
                        }
                        else
                        {
                            <div class="lt-alert lt-alert--warning" style="padding:8px 12px;border-radius:8px;font-size:.85rem">
                                <i class="bi bi-exclamation-triangle"></i>
                                Chưa có khối lớp nào. Vui lòng cấu hình hệ thống.
                            </div>
                            <input asp-for="GradeLevelId" type="hidden" value="0"/>
                        }
                    </div>

                    <!-- Giáo viên chủ nhiệm -->
                    <div class="lt-form-group">
                        <label class="lt-label" asp-for="HomeRoomTeacherId">Giáo viên chủ nhiệm</label>
                        <select asp-for="HomeRoomTeacherId" class="lt-select">
                            <option value="">— Chưa phân công —</option>
                            @foreach (var t in teachers)
                            {
                                <option value="@t.UserId">@t.FullName (@t.TeacherCode)</option>
                            }
                        </select>
                        <span class="lt-form-hint">Có thể bổ sung sau khi tạo lớp</span>
                    </div>

                    <div class="row g-3">
                        <!-- Sĩ số tối đa -->
                        <div class="col-6">
                            <div class="lt-form-group">
                                <label class="lt-label" asp-for="MaxStudents">Sĩ số tối đa</label>
                                <input asp-for="MaxStudents" type="number" class="lt-input"
                                       min="1" max="60" value="40"/>
                            </div>
                        </div>
                        <!-- Phòng học -->
                        <div class="col-6">
                            <div class="lt-form-group">
                                <label class="lt-label" asp-for="RoomNumber">Phòng học</label>
                                <input asp-for="RoomNumber" class="lt-input" placeholder="VD: A101"/>
                            </div>
                        </div>
                    </div>

                    <div class="lt-flex-between" style="margin-top:24px">
                        <a asp-action="Index" asp-route-academicYearId="@(Model?.AcademicYearId)"
                           class="lt-btn lt-btn--outline">Hủy</a>
                        <button type="submit" class="lt-btn lt-btn--primary" data-testid="btn-submit-class">
                            <i class="bi bi-check-lg"></i> Tạo lớp học
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}
