@{
    Layout = null;
    ViewData["Title"] = "Quên mật khẩu";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Quên mật khẩu — Lumina Tutors</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/lumina.css"/>
</head>
<body class="lt-auth-body">

<div class="lt-auth-center">

    <!-- Back link -->
    <a asp-controller="Auth" asp-action="Login" class="lt-auth-back">
        <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
    </a>

    <div class="lt-auth-card">

        <!-- Icon -->
        <div class="lt-auth-icon">
            <i class="bi bi-key-fill"></i>
        </div>

        <h1 class="lt-auth-title">Quên mật khẩu?</h1>
        <p class="lt-auth-subtitle">
            Nhập địa chỉ email tài khoản của bạn. Chúng tôi sẽ gửi mã OTP để đặt lại mật khẩu.
        </p>

        @if (TempData["Info"] != null)
        {
            <div class="lt-alert lt-alert--info lt-mb-4">
                <i class="bi bi-info-circle-fill"></i>
                <span>@TempData["Info"]</span>
            </div>
        }

        <form asp-action="ForgotPassword" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="lt-form-group">
                <label class="lt-label" for="email">
                    <i class="bi bi-envelope"></i> Địa chỉ email
                </label>
                <input type="email"
                       id="email"
                       name="email"
                       class="lt-input"
                       placeholder="ten@truong.edu.vn"
                       autocomplete="email"
                       required
                       autofocus/>
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState["email"]?.Errors.Count > 0)
                {
                    <span class="lt-form-error">@ViewData.ModelState["email"]!.Errors[0].ErrorMessage</span>
                }
            </div>

            <button type="submit" class="lt-btn lt-btn--primary lt-btn--full">
                <i class="bi bi-send-fill"></i> Gửi mã OTP
            </button>
        </form>

        <p class="lt-auth-footer-link">
            Đã nhớ mật khẩu?
            <a asp-controller="Auth" asp-action="Login">Đăng nhập ngay</a>
        </p>
    </div>

    <p class="lt-auth-copyright">© @DateTime.Now.Year Lumina Tutors. Bảo lưu mọi quyền.</p>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
