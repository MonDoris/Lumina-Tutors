@model LuminaTutors.Domain.Common.PagedResult<LuminaTutors.Application.DTOs.Auth.InviteLinkDto>
@{
    ViewData["Title"] = "Quản lý liên kết mời";
}

<div class="lt-page-header">
    <div>
        <h1 class="lt-page-title">Liên kết mời</h1>
        <p class="lt-page-subtitle">Tạo và quản lý liên kết kích hoạt tài khoản</p>
    </div>
    <button class="lt-btn lt-btn--gold" data-bs-toggle="modal" data-bs-target="#createModal"
            data-testid="btn-create-invite">
        <i class="bi bi-plus-lg"></i> Tạo liên kết mới
    </button>
</div>

<div class="lt-card">
    <div class="lt-card__body" style="padding:0">
        <table class="lt-table" data-testid="invite-table">
            <thead>
                <tr>
                    <th>Vai trò</th>
                    <th>Email nhận</th>
                    <th>Học sinh liên kết</th>
                    <th>Hết hạn</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th style="width:120px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Items.Count == 0)
                {
                    <tr><td colspan="7" style="text-align:center;padding:40px;color:#9ca3af">
                        <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                        Chưa có liên kết mời nào
                    </td></tr>
                }
                @foreach (var inv in Model?.Items ?? new List<LuminaTutors.Application.DTOs.Auth.InviteLinkDto>())
                {
                    <tr data-testid="invite-row">
                        <td><span class="lt-badge lt-badge--navy">@inv.TargetRoleName</span></td>
                        <td>@(inv.TargetEmail ?? "—")</td>
                        <td>@(inv.LinkedStudentName ?? "—")</td>
                        <td style="font-size:0.82rem;color:#6b7280">
                            @inv.ExpiresAt.ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td>
                            @if (inv.IsValid)
                            {
                                <span class="lt-badge lt-badge--success"><i class="bi bi-check-circle"></i> Hợp lệ</span>
                            }
                            else
                            {
                                <span class="lt-badge lt-badge--gray"><i class="bi bi-x-circle"></i> Hết hạn/Đã dùng</span>
                            }
                        </td>
                        <td style="font-size:0.82rem;color:#6b7280">@inv.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div style="display:flex;gap:6px;align-items:center">
                                @if (inv.IsValid)
                                {
                                    <button class="lt-btn lt-btn--outline lt-btn--sm"
                                            onclick="copyLink('@inv.Token')"
                                            title="Sao chép liên kết">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                    <form asp-controller="Auth" asp-action="RevokeInviteLink" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@inv.InviteId"/>
                                        <button type="submit" class="lt-btn lt-btn--danger lt-btn--sm"
                                                onclick="return confirm('Thu hồi liên kết này?')"
                                                data-testid="btn-revoke">
                                            <i class="bi bi-ban"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model?.TotalPages > 1)
    {
        <div class="lt-card__footer d-flex justify-content-between align-items-center">
            <span style="font-size:0.82rem;color:#6b7280">
                Tổng: @Model.TotalCount liên kết
            </span>
            <div class="lt-pagination">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-action="InviteLinks" asp-route-page="@i"
                       class="lt-page-btn @(i == Model.PageNumber ? "active" : "")">@i</a>
                }
            </div>
        </div>
    }
</div>

<!-- ── Create Modal ── -->
<div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none;box-shadow:0 20px 60px rgba(0,0,0,0.15)">
            <div class="modal-header" style="border-bottom:1px solid #f0f0f0;padding:20px 24px">
                <h5 class="modal-title lt-card__title" id="createModalLabel">Tạo liên kết mời mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Auth" asp-action="CreateInviteLink" method="post" data-testid="create-invite-form">
                @Html.AntiForgeryToken()
                <div class="modal-body" style="padding:24px">
                    <div class="lt-form-group">
                        <label class="lt-label">Vai trò <span style="color:var(--lt-danger)">*</span></label>
                        <select name="TargetRoleId" class="lt-select" required data-testid="select-role">
                            <option value="">-- Chọn vai trò --</option>
                            <option value="2">Giáo viên (TEACHER)</option>
                            <option value="3">Học sinh (STUDENT)</option>
                            <option value="4">Phụ huynh (PARENT)</option>
                            <option value="5">Giám thị (SUPERVISOR)</option>
                            <option value="6">Kế toán (ACCOUNTANT)</option>
                        </select>
                    </div>
                    <div class="lt-form-group">
                        <label class="lt-label">Email nhận (tùy chọn)</label>
                        <input type="email" name="TargetEmail" class="lt-input"
                               placeholder="email@example.com" data-testid="input-target-email"/>
                    </div>
                    <div class="lt-form-group">
                        <label class="lt-label">ID Học sinh liên kết (cho Phụ huynh)</label>
                        <input type="number" name="LinkedStudentId" class="lt-input"
                               placeholder="Bỏ trống nếu không cần" data-testid="input-student-id"/>
                    </div>
                    <div class="lt-form-group" style="margin-bottom:0">
                        <label class="lt-label">Thời hạn hiệu lực</label>
                        <select name="ExpiryHours" class="lt-select" data-testid="select-expiry">
                            <option value="24">24 giờ</option>
                            <option value="48">48 giờ</option>
                            <option value="72" selected>72 giờ (3 ngày)</option>
                            <option value="168">7 ngày</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer" style="padding:16px 24px;border-top:1px solid #f0f0f0;gap:8px">
                    <button type="button" class="lt-btn lt-btn--outline" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="lt-btn lt-btn--gold" data-testid="btn-submit-invite">
                        <i class="bi bi-link-45deg"></i> Tạo liên kết
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function copyLink(token) {
    const url = `${window.location.origin}/Auth/Activate?token=${token}`;
    navigator.clipboard.writeText(url).then(() => {
        // Small toast
        const t = document.createElement('div');
        t.textContent = '✓ Đã sao chép liên kết';
        t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#0f1c2e;color:#fff;padding:10px 18px;border-radius:8px;font-size:.85rem;z-index:9999;animation:fadeUp .3s ease';
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 2500);
    });
}
</script>
}
