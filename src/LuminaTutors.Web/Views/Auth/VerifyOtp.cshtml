@{
    Layout = null;
    ViewData["Title"] = "Xác thực OTP";
    var email = ViewData["Email"] as string ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Xác thực OTP — Lumina Tutors</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/lumina.css"/>
    <style>
        .lt-otp-row { display:flex; gap:10px; justify-content:center; margin-bottom:32px; }
        .lt-otp-box {
            width:52px; height:64px;
            border:1.5px solid var(--lt-border);
            border-radius:10px;
            background:var(--lt-surface);
            font-size:1.5rem; font-weight:700;
            color:var(--lt-navy);
            text-align:center;
            transition:border-color .15s, transform .15s, box-shadow .15s;
        }
        .lt-otp-box:focus {
            outline:none;
            border-color:var(--lt-gold);
            box-shadow:0 0 0 3px rgba(201,168,76,.18);
            transform:translateY(-2px);
        }
    </style>
</head>
<body class="lt-auth-body">

<div class="lt-auth-center">

    <a asp-controller="Auth" asp-action="ForgotPassword" class="lt-auth-back">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>

    <div class="lt-auth-card" style="text-align:center">

        <div class="lt-auth-icon">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <h1 class="lt-auth-title">Nhập mã OTP</h1>
        <p class="lt-auth-subtitle">
            Mã gồm 6 chữ số đã được gửi đến
            @if (!string.IsNullOrEmpty(email))
            {
                <strong>@email</strong>
            }
            else
            {
                <span>hộp thư email của bạn</span>
            }
        </p>

        <form asp-action="VerifyOtp" method="post" id="otpForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="email" value="@email"/>
            <input type="hidden" name="otp" id="otpHidden"/>

            <div class="lt-otp-row" id="otpContainer">
                <input class="lt-otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]" autofocus/>
                <input class="lt-otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]"/>
                <input class="lt-otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]"/>
                <input class="lt-otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]"/>
                <input class="lt-otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]"/>
                <input class="lt-otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]"/>
            </div>

            <button type="submit" class="lt-btn lt-btn--primary lt-btn--full lt-mb-3" id="btnVerify" disabled>
                <i class="bi bi-check-circle-fill"></i> Xác nhận
            </button>
        </form>

        <p class="lt-text-sm lt-text-muted">
            Chưa nhận được mã?
            <a asp-controller="Auth" asp-action="ForgotPassword"
               asp-route-email="@email"
               class="lt-link">Gửi lại mã</a>
        </p>
    </div>

    <p class="lt-auth-copyright">© @DateTime.Now.Year Lumina Tutors. Bảo lưu mọi quyền.</p>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
const container = document.getElementById('otpContainer');
const inputs    = container.querySelectorAll('.lt-otp-box');
const hidden    = document.getElementById('otpHidden');
const btnVerify = document.getElementById('btnVerify');

inputs.forEach((input, idx) => {
    input.addEventListener('input', e => {
        e.target.value = e.target.value.replace(/\D/g, '').slice(-1);
        if (e.target.value && idx < inputs.length - 1) inputs[idx + 1].focus();
        syncHidden();
    });
    input.addEventListener('keydown', e => {
        if (e.key === 'Backspace' && !e.target.value && idx > 0) inputs[idx - 1].focus();
    });
    input.addEventListener('paste', e => {
        e.preventDefault();
        const text = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '');
        [...text].slice(0, 6).forEach((ch, i) => { if (inputs[i]) inputs[i].value = ch; });
        syncHidden();
        inputs[Math.min(text.length, 5)].focus();
    });
});

function syncHidden() {
    const val = [...inputs].map(i => i.value).join('');
    hidden.value = val;
    btnVerify.disabled = val.length < 6;
}
</script>
</body>
</html>
