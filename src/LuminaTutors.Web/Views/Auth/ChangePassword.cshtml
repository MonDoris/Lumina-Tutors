@model LuminaTutors.Application.DTOs.Auth.ChangePasswordRequest
@{ ViewData["Title"] = "Đổi mật khẩu"; }

<div class="lt-page-header">
    <div>
        <h1 class="lt-page-title">Đổi mật khẩu</h1>
        <p class="lt-page-subtitle">Cập nhật mật khẩu để bảo vệ tài khoản của bạn</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="lt-card">
            <div class="lt-card__body">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="lt-alert lt-alert--danger">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <div>@Html.ValidationSummary(true)</div>
                    </div>
                }

                <form asp-controller="Auth" asp-action="ChangePassword" method="post" data-testid="change-password-form">
                    @Html.AntiForgeryToken()

                    <div class="lt-form-group">
                        <label asp-for="CurrentPassword" class="lt-label">Mật khẩu hiện tại</label>
                        <input asp-for="CurrentPassword" type="password" class="lt-input"
                               placeholder="••••••••" data-testid="input-current-pw"/>
                        <span asp-validation-for="CurrentPassword" class="lt-input-error"><i class="bi bi-exclamation-circle"></i></span>
                    </div>

                    <div class="lt-form-group">
                        <label asp-for="NewPassword" class="lt-label">Mật khẩu mới (tối thiểu 8 ký tự)</label>
                        <input asp-for="NewPassword" type="password" class="lt-input"
                               placeholder="••••••••" data-testid="input-new-pw"/>
                        <span asp-validation-for="NewPassword" class="lt-input-error"><i class="bi bi-exclamation-circle"></i></span>
                    </div>

                    <div class="lt-form-group">
                        <label asp-for="ConfirmNewPassword" class="lt-label">Xác nhận mật khẩu mới</label>
                        <input asp-for="ConfirmNewPassword" type="password" class="lt-input"
                               placeholder="••••••••" data-testid="input-confirm-pw"/>
                        <span asp-validation-for="ConfirmNewPassword" class="lt-input-error"><i class="bi bi-exclamation-circle"></i></span>
                    </div>

                    <div style="display:flex;gap:10px;margin-top:24px">
                        <a asp-controller="Dashboard" asp-action="Index" class="lt-btn lt-btn--outline">
                            Hủy
                        </a>
                        <button type="submit" class="lt-btn lt-btn--primary flex-grow-1"
                                style="justify-content:center" data-testid="btn-change-pw">
                            <i class="bi bi-key"></i> Cập nhật mật khẩu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
