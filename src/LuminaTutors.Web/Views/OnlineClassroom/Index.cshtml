@using LuminaTutors.Application.DTOs.OnlineClassroom
@using LuminaTutors.Domain.Enums
@using System.Security.Claims
@{
    ViewData["Title"] = "Phòng học Online";
    var sessions = ViewBag.Sessions as List<OnlineSessionListDto> ?? new();
    var userId   = (int)(ViewBag.UserId ?? 0);
    var roleVal  = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var isTeacher = roleVal is "TEACHER" or "ADMIN";

    var live      = sessions.Where(s => s.Status == OnlineSessionStatus.Live).ToList();
    var scheduled = sessions.Where(s => s.Status == OnlineSessionStatus.Scheduled).ToList();
    var past      = sessions.Where(s => s.Status == OnlineSessionStatus.Ended).ToList();
}

<div class="lt-page-header">
    <div>
        <h1 class="lt-page-title">
            <i class="bi bi-camera-video-fill" style="color:var(--lt-gold);margin-right:8px"></i>
            Phòng học Online
        </h1>
        <p class="lt-page-subtitle">Lớp học trực tuyến tự xây dựng — video, whiteboard, chat</p>
    </div>
    <div style="display:flex;gap:8px">
        <a asp-action="Join" class="lt-btn lt-btn--outline">
            <i class="bi bi-key-fill"></i> Nhập mã phòng
        </a>
        @if (isTeacher)
        {
            <a asp-action="Create" class="lt-btn lt-btn--primary">
                <i class="bi bi-plus-lg"></i> Tạo phòng
            </a>
        }
    </div>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="lt-alert lt-alert--success lt-mb-4"><i class="bi bi-check-circle-fill"></i> @ok</div>
}
@if (TempData["Error"] is string err)
{
    <div class="lt-alert lt-alert--danger lt-mb-4"><i class="bi bi-exclamation-triangle-fill"></i> @err</div>
}

@* ── LIVE ── *@
@if (live.Count > 0)
{
    <div class="lt-mb-5">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:.75rem">
            <span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:var(--lt-danger);
                         box-shadow:0 0 0 3px rgba(220,38,38,.2);animation:pulse 1.5s infinite"></span>
            <span style="font-size:.8rem;font-weight:700;color:var(--lt-danger);text-transform:uppercase;letter-spacing:.05em">
                Đang phát trực tiếp
            </span>
        </div>
        <div class="row g-3">
            @foreach (var s in live)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="lt-card lt-card--hover"
                         style="border:2px solid rgba(220,38,38,.25);background:rgba(220,38,38,.03)">
                        <div class="lt-card__body">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px">
                                <div style="min-width:0;flex:1">
                                    <div style="font-weight:700;font-size:.94rem;white-space:nowrap;
                                                overflow:hidden;text-overflow:ellipsis" title="@s.Title">@s.Title</div>
                                    <div style="font-size:.76rem;color:var(--lt-text-muted);margin-top:2px">
                                        <i class="bi bi-person-fill"></i> @s.TeacherName
                                    </div>
                                </div>
                                <span class="lt-badge"
                                      style="background:rgba(220,38,38,.1);color:var(--lt-danger);border:none;font-size:.68rem;flex-shrink:0;margin-left:8px">
                                    ● LIVE
                                </span>
                            </div>
                            <div style="font-size:.76rem;color:var(--lt-text-muted);margin-bottom:12px">
                                <i class="bi bi-people-fill"></i> @s.ParticipantCount/@s.MaxParticipants người tham gia
                                @if (s.StartedAt.HasValue)
                                {
                                    <span class="lt-ms-2"><i class="bi bi-clock"></i> @s.StartedAt.Value.ToLocalTime().ToString("HH:mm")</span>
                                }
                            </div>
                            <div style="display:flex;gap:6px">
                                <a asp-action="Room" asp-route-id="@s.Id"
                                   class="lt-btn lt-btn--primary lt-btn--sm" style="flex:1;justify-content:center">
                                    <i class="bi bi-camera-video-fill"></i> Vào phòng
                                </a>
                                @if (s.TeacherId == userId)
                                {
                                    <form asp-action="End" asp-route-id="@s.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="lt-btn lt-btn--sm lt-btn--outline"
                                                style="border-color:var(--lt-danger);color:var(--lt-danger)"
                                                onclick="return confirm('Kết thúc buổi học?')">
                                            <i class="bi bi-stop-fill"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@* ── SCHEDULED ── *@
@if (scheduled.Count > 0)
{
    <div class="lt-mb-5">
        <h2 class="lt-section-label lt-mb-3">Sắp diễn ra</h2>
        <div class="row g-3">
            @foreach (var s in scheduled)
            {
                var isOwner = s.TeacherId == userId;
                <div class="col-md-6 col-xl-4">
                    <div class="lt-card lt-card--hover">
                        <div class="lt-card__body">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px">
                                <div style="min-width:0;flex:1">
                                    <div style="font-weight:700;font-size:.92rem;white-space:nowrap;
                                                overflow:hidden;text-overflow:ellipsis" title="@s.Title">@s.Title</div>
                                    <div style="font-size:.76rem;color:var(--lt-text-muted);margin-top:2px">
                                        <i class="bi bi-person-fill"></i> @s.TeacherName
                                    </div>
                                </div>
                                <span class="lt-badge" style="background:rgba(201,169,110,.12);color:var(--lt-gold);
                                      border:none;font-size:.68rem;flex-shrink:0;margin-left:8px">
                                    <i class="bi bi-clock"></i> Sắp mở
                                </span>
                            </div>
                            <div style="display:flex;gap:12px;font-size:.75rem;color:var(--lt-text-muted);margin-bottom:10px">
                                @if (s.ScheduledAt.HasValue)
                                {
                                    <span><i class="bi bi-calendar-event-fill"></i>
                                        @s.ScheduledAt.Value.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</span>
                                }
                                <span><i class="bi bi-key-fill" style="color:var(--lt-gold)"></i>
                                    <strong style="font-family:monospace;color:var(--lt-navy)">@s.RoomCode</strong></span>
                            </div>
                            @if (isOwner)
                            {
                                <div style="display:flex;gap:6px">
                                    <form asp-action="Start" asp-route-id="@s.Id" method="post" style="flex:1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="lt-btn lt-btn--primary lt-btn--sm"
                                                style="width:100%;justify-content:center">
                                            <i class="bi bi-broadcast"></i> Bắt đầu ngay
                                        </button>
                                    </form>
                                    <a asp-action="Edit" asp-route-id="@s.Id" class="lt-btn lt-btn--sm lt-btn--outline">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@s.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="lt-btn lt-btn--sm lt-btn--outline"
                                                style="border-color:var(--lt-danger);color:var(--lt-danger)"
                                                onclick="return confirm('Xóa phòng học?')">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <div style="text-align:center;font-size:.78rem;color:var(--lt-text-muted);
                                            padding:.5rem;background:var(--lt-bg-subtle);border-radius:8px">
                                    <i class="bi bi-hourglass-split"></i> Chờ giáo viên bắt đầu
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@* ── EMPTY STATE ── *@
@if (live.Count == 0 && scheduled.Count == 0)
{
    <div class="lt-card lt-mb-4">
        <div class="lt-card__body">
            <div class="lt-empty">
                <i class="bi bi-camera-video" style="font-size:3rem;color:var(--lt-navy-100)"></i>
                <div class="lt-empty__title">Chưa có phòng học nào</div>
                <div class="lt-empty__subtitle">
                    @if (isTeacher)
                    {
                        <span>Tạo phòng học đầu tiên để bắt đầu.</span>
                    }
                    else
                    {
                        <span>Nhập mã phòng do giáo viên cung cấp để tham gia.</span>
                    }
                </div>
                @if (isTeacher)
                {
                    <a asp-action="Create" class="lt-btn lt-btn--primary lt-mt-3">
                        <i class="bi bi-plus-lg"></i> Tạo phòng học
                    </a>
                }
            </div>
        </div>
    </div>
}

@* ── PAST (teacher only) ── *@
@if (isTeacher && past.Count > 0)
{
    <div class="lt-mt-5">
        <h2 class="lt-section-label lt-mb-3">Lịch sử buổi học</h2>
        <div class="lt-card">
            <div class="lt-card__body" style="padding:0">
                <table class="lt-table">
                    <thead>
                        <tr>
                            <th>Tên phòng</th>
                            <th style="width:100px">Mã phòng</th>
                            <th style="width:140px">Thời gian</th>
                            <th style="width:80px;text-align:center">Tham dự</th>
                            <th style="width:60px;text-align:right"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in past)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:600;font-size:.85rem">@s.Title</div>
                                    <div style="font-size:.75rem;color:var(--lt-text-muted)">
                                        @s.TeacherName
                                    </div>
                                </td>
                                <td style="font-family:monospace;font-size:.8rem;font-weight:700;
                                           color:var(--lt-navy)">@s.RoomCode</td>
                                <td style="font-size:.76rem;color:var(--lt-text-muted)">
                                    @if (s.StartedAt.HasValue)
                                    {
                                        @s.StartedAt.Value.ToLocalTime().ToString("HH:mm dd/MM/yyyy")
                                    }
                                </td>
                                <td style="text-align:center;font-size:.82rem">
                                    @s.ParticipantCount
                                </td>
                                <td style="text-align:right">
                                    <form asp-action="Delete" asp-route-id="@s.Id" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="lt-btn lt-btn--sm lt-btn--outline"
                                                style="border-color:var(--lt-danger);color:var(--lt-danger)"
                                                onclick="return confirm('Xóa phòng học này?')">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section Styles {
    <style>
        @@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
        .lt-section-label {
            font-size: .82rem;
            font-weight: 700;
            color: var(--lt-text-muted);
            text-transform: uppercase;
            letter-spacing: .05em;
        }
    </style>
}
