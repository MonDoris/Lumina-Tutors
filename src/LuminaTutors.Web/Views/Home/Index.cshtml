@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Lumina Tutors — Nền tảng quản lý giáo dục toàn diện</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --navy:       #060d1f;
            --navy-2:     #0d1a35;
            --navy-3:     #1a2d52;
            --blue:       #2563eb;
            --blue-l:     #3b82f6;
            --blue-ll:    #60a5fa;
            --gold:       #f59e0b;
            --gold-l:     #fbbf24;
            --white:      #ffffff;
            --gray-50:    #f8fafc;
            --gray-100:   #f1f5f9;
            --gray-200:   #e2e8f0;
            --gray-300:   #cbd5e1;
            --gray-400:   #94a3b8;
            --gray-500:   #64748b;
            --gray-600:   #475569;
            --gray-700:   #334155;
            --green:      #10b981;
            --purple:     #8b5cf6;
            --teal:       #14b8a6;
            --rose:       #f43f5e;
        }

        html { scroll-behavior: smooth; }
        body {
            font-family: 'Inter', sans-serif;
            color: var(--gray-700);
            background: #fff;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }

        /* ══════════════ NAVBAR ══════════════ */
        .nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
            padding: 0 48px;
            height: 68px;
            display: flex; align-items: center; justify-content: space-between;
            transition: background .3s, box-shadow .3s, border-color .3s;
        }
        .nav.scrolled {
            background: rgba(255,255,255,.95);
            backdrop-filter: blur(16px);
            box-shadow: 0 1px 0 rgba(0,0,0,.08);
        }
        .nav__logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.35rem; font-weight: 800;
            color: #fff; text-decoration: none;
            display: flex; align-items: center; gap: 8px;
            transition: color .3s;
        }
        .nav__logo-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--gold); display: inline-block;
        }
        .nav.scrolled .nav__logo { color: var(--navy); }
        .nav__links { display: flex; gap: 4px; }
        .nav__link {
            font-size: .875rem; font-weight: 500;
            color: rgba(255,255,255,.8); text-decoration: none;
            padding: 8px 16px; border-radius: 8px;
            transition: color .2s, background .2s;
        }
        .nav__link:hover { color: #fff; background: rgba(255,255,255,.12); }
        .nav.scrolled .nav__link { color: var(--gray-600); }
        .nav.scrolled .nav__link:hover { color: var(--blue); background: #eff6ff; }
        .nav__actions { display: flex; gap: 10px; align-items: center; }
        .nav-login {
            font-size: .875rem; font-weight: 500;
            color: rgba(255,255,255,.85); text-decoration: none;
            padding: 9px 18px; border-radius: 8px;
            border: 1px solid rgba(255,255,255,.25);
            transition: all .2s;
        }
        .nav-login:hover { color: #fff; border-color: rgba(255,255,255,.6); background: rgba(255,255,255,.1); }
        .nav.scrolled .nav-login { color: var(--gray-700); border-color: var(--gray-200); }
        .nav.scrolled .nav-login:hover { color: var(--blue); border-color: var(--blue); background: #eff6ff; }
        .nav-register {
            font-size: .875rem; font-weight: 600;
            color: var(--navy); background: var(--gold);
            text-decoration: none; padding: 9px 20px; border-radius: 8px;
            transition: background .2s, transform .15s, box-shadow .2s;
            box-shadow: 0 2px 10px rgba(245,158,11,.4);
        }
        .nav-register:hover { background: var(--gold-l); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(245,158,11,.5); }

        /* ══════════════ HERO ══════════════ */
        .hero {
            min-height: 100vh;
            position: relative; overflow: hidden;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            padding: 120px 48px 80px;
        }

        /* Video background */
        .hero__video {
            position: absolute; inset: 0; z-index: 0;
            width: 100%; height: 100%;
            object-fit: cover;
            pointer-events: none;
        }

        /* Dark overlay — giữ text dễ đọc */
        .hero__overlay {
            position: absolute; inset: 0; z-index: 1;
            background: linear-gradient(
                135deg,
                rgba(6,13,31,.88)  0%,
                rgba(13,26,53,.80) 50%,
                rgba(14,31,74,.75) 100%
            );
        }

        /* Grid overlay */
        .hero-grid {
            position: absolute; inset: 0; z-index: 1;
            background-image:
                linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
            background-size: 60px 60px;
        }

        .hero__inner {
            position: relative; z-index: 3;
            max-width: 900px; text-align: center;
        }
        .hero__badge {
            display: inline-flex; align-items: center; gap: 8px;
            font-size: .8rem; font-weight: 600;
            color: var(--gold); letter-spacing: .8px; text-transform: uppercase;
            background: rgba(245,158,11,.1); border: 1px solid rgba(245,158,11,.3);
            padding: 6px 16px; border-radius: 99px; margin-bottom: 28px;
        }
        .hero__badge i { font-size: .9rem; }
        .hero__title {
            font-size: clamp(2.4rem, 6vw, 4.5rem);
            font-weight: 900; line-height: 1.1;
            color: #fff; letter-spacing: -1px;
            margin-bottom: 24px;
        }
        .hero__title-grad {
            background: linear-gradient(90deg, var(--gold) 0%, #fde68a 50%, var(--blue-ll) 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero__sub {
            font-size: 1.125rem; color: rgba(255,255,255,.6);
            line-height: 1.75; max-width: 600px; margin: 0 auto 40px;
        }
        .hero__cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
        .btn-hero-primary {
            font-size: 1rem; font-weight: 700;
            color: var(--navy); background: var(--gold);
            text-decoration: none; padding: 15px 36px; border-radius: 10px;
            box-shadow: 0 4px 24px rgba(245,158,11,.45);
            transition: all .2s; display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-hero-primary:hover { background: var(--gold-l); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(245,158,11,.55); }
        .btn-hero-ghost {
            font-size: 1rem; font-weight: 600;
            color: rgba(255,255,255,.85); text-decoration: none;
            padding: 15px 32px; border-radius: 10px;
            border: 1px solid rgba(255,255,255,.2);
            transition: all .2s; display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-hero-ghost:hover { color: #fff; border-color: rgba(255,255,255,.6); background: rgba(255,255,255,.07); transform: translateY(-2px); }

        /* Dashboard preview card */
        .hero__preview {
            position: relative; z-index: 3;
            max-width: 960px; width: 100%;
            margin: 60px auto 0;
        }
        .hero__screen {
            background: #111827; border-radius: 16px;
            border: 1px solid rgba(255,255,255,.12);
            box-shadow: 0 40px 100px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.06);
            overflow: hidden;
        }
        .screen__bar {
            background: #1f2937; height: 38px;
            display: flex; align-items: center; gap: 8px; padding: 0 16px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .screen__dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
        .screen__url {
            flex: 1; background: rgba(255,255,255,.07); border-radius: 6px;
            height: 22px; margin: 0 12px; display: flex; align-items: center; padding: 0 10px;
        }
        .screen__url-text { font-size: .7rem; color: rgba(255,255,255,.35); font-family: monospace; }
        .screen__body {
            display: grid; grid-template-columns: 220px 1fr;
            min-height: 360px;
        }
        .screen__sidebar {
            background: #060d1f; padding: 20px 14px;
            display: flex; flex-direction: column; gap: 4px;
            border-right: 1px solid rgba(255,255,255,.07);
        }
        .screen__logo-area { padding: 0 8px 16px; border-bottom: 1px solid rgba(255,255,255,.08); margin-bottom: 10px; }
        .screen__logo-txt { font-size: .9rem; font-weight: 700; color: var(--gold); font-family: 'Playfair Display', serif; }
        .s-item {
            height: 34px; border-radius: 7px; display: flex; align-items: center;
            gap: 8px; padding: 0 10px; cursor: pointer;
        }
        .s-item.act { background: rgba(37,99,235,.25); }
        .s-item-icon { width: 16px; height: 16px; border-radius: 4px; background: rgba(255,255,255,.12); flex-shrink: 0; }
        .s-item.act .s-item-icon { background: var(--blue-l); }
        .s-item-text { height: 6px; border-radius: 3px; background: rgba(255,255,255,.12); flex: 1; }
        .s-item.act .s-item-text { background: rgba(255,255,255,.5); }
        .screen__main { padding: 20px; display: flex; flex-direction: column; gap: 14px; background: #f8fafc; }
        .s-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
        .s-stat {
            background: #fff; border-radius: 10px; padding: 12px 14px;
            border: 1px solid #e2e8f0;
        }
        .s-stat-val { font-size: 1.25rem; font-weight: 800; color: #0f172a; }
        .s-stat-lbl { height: 6px; border-radius: 3px; background: #e2e8f0; width: 65%; margin-top: 6px; }
        .s-stat-icon { width: 28px; height: 28px; border-radius: 6px; margin-bottom: 8px; }
        .s-row { display: grid; grid-template-columns: 2fr 1fr; gap: 10px; }
        .s-card { background: #fff; border-radius: 10px; border: 1px solid #e2e8f0; overflow: hidden; }
        .s-card-head { height: 32px; background: #f8fafc; border-bottom: 1px solid #e2e8f0; display: flex; align-items: center; padding: 0 14px; gap: 6px; }
        .s-card-head-dot { width: 8px; height: 8px; border-radius: 50%; }
        .s-card-head-label { height: 6px; border-radius: 3px; background: #cbd5e1; width: 80px; }
        .s-table { padding: 8px; display: flex; flex-direction: column; gap: 6px; }
        .s-tr { height: 20px; border-radius: 5px; background: #f8fafc; display: flex; align-items: center; padding: 0 8px; gap: 8px; }
        .s-td { height: 5px; border-radius: 2px; background: #e2e8f0; }
        .s-chart { padding: 12px; }
        .s-bars { display: flex; gap: 5px; align-items: flex-end; height: 80px; }
        .s-bar { flex: 1; border-radius: 4px 4px 0 0; background: linear-gradient(to top, var(--blue), var(--blue-ll)); opacity: .7; }
        .s-bar:nth-child(4) { opacity: 1; }

        /* Floating UI cards over hero */
        .hero__floats {
            position: absolute; inset: 0; z-index: 4; pointer-events: none;
        }
        .hero__float {
            position: absolute; background: rgba(255,255,255,.08);
            backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,.18); border-radius: 14px;
            padding: 12px 16px; display: flex; align-items: center; gap: 10px;
        }
        .hero__float-1 { left: 2%; top: 28%; animation: float1 6s ease-in-out infinite; }
        .hero__float-2 { right: 2%; top: 40%; animation: float2 7s ease-in-out infinite; }
        @@keyframes float1 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
        @@keyframes float2 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(10px)} }
        .hf-icon {
            width: 38px; height: 38px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
            flex-shrink: 0;
        }
        .hf-text { font-size: .8rem; font-weight: 600; color: #fff; white-space: nowrap; }
        .hf-sub  { font-size: .7rem; color: rgba(255,255,255,.55); white-space: nowrap; }
        .hf-pill {
            font-size: .7rem; font-weight: 700; padding: 2px 8px; border-radius: 99px;
        }
        .pill-green { background: rgba(16,185,129,.25); color: #34d399; }
        .pill-blue  { background: rgba(59,130,246,.25); color: #93c5fd; }

        /* ══════════════ STATS ══════════════ */
        .stats-bar {
            background: linear-gradient(90deg, var(--blue) 0%, #1d4ed8 100%);
            padding: 40px 48px;
        }
        .stats-bar__inner {
            max-width: 1100px; margin: 0 auto;
            display: grid; grid-template-columns: repeat(4, 1fr);
            divide-x: 1px solid rgba(255,255,255,.2);
            gap: 0;
        }
        .stat-item {
            text-align: center; padding: 0 24px;
            border-right: 1px solid rgba(255,255,255,.2);
        }
        .stat-item:last-child { border-right: none; }
        .stat-num {
            font-size: 2.5rem; font-weight: 900; color: #fff;
            letter-spacing: -1px; line-height: 1;
        }
        .stat-num span { color: var(--gold-l); }
        .stat-lbl { font-size: .85rem; color: rgba(255,255,255,.65); margin-top: 6px; }

        /* ══════════════ FEATURES ══════════════ */
        .features { padding: 100px 48px; background: #fff; }
        .features__inner { max-width: 1200px; margin: 0 auto; }

        .section-badge {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: .75rem; font-weight: 700; letter-spacing: 1px;
            text-transform: uppercase; color: var(--blue);
            background: #eff6ff; border: 1px solid #bfdbfe;
            padding: 5px 14px; border-radius: 99px; margin-bottom: 16px;
        }
        .section-title {
            font-size: clamp(1.75rem, 3vw, 2.5rem);
            font-weight: 900; color: var(--navy);
            letter-spacing: -0.5px; line-height: 1.2;
            margin-bottom: 16px;
        }
        .section-sub {
            font-size: 1rem; color: var(--gray-500); line-height: 1.75;
            max-width: 560px;
        }
        .features__header {
            display: grid; grid-template-columns: 1fr 1fr; gap: 48px;
            align-items: end; margin-bottom: 60px;
        }
        .features__right { text-align: right; }
        .btn-outline-blue {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: .875rem; font-weight: 600; color: var(--blue);
            text-decoration: none; padding: 10px 20px; border-radius: 8px;
            border: 1.5px solid var(--blue);
            transition: all .2s;
        }
        .btn-outline-blue:hover { background: var(--blue); color: #fff; }

        .features__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
        .feat-card {
            border-radius: 20px; padding: 32px 28px;
            border: 1px solid var(--gray-100);
            position: relative; overflow: hidden;
            transition: transform .25s, box-shadow .25s;
            background: #fff;
        }
        .feat-card:hover { transform: translateY(-6px); box-shadow: 0 20px 60px rgba(0,0,0,.1); }
        .feat-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
        }
        .feat-card.fc-blue::before  { background: linear-gradient(90deg, var(--blue), var(--blue-ll)); }
        .feat-card.fc-gold::before  { background: linear-gradient(90deg, var(--gold), var(--gold-l)); }
        .feat-card.fc-green::before { background: linear-gradient(90deg, var(--green), #34d399); }
        .feat-card.fc-purple::before{ background: linear-gradient(90deg, var(--purple), #a78bfa); }
        .feat-card.fc-teal::before  { background: linear-gradient(90deg, var(--teal), #2dd4bf); }
        .feat-card.fc-rose::before  { background: linear-gradient(90deg, var(--rose), #fb7185); }
        .feat-card__icon {
            width: 56px; height: 56px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem; margin-bottom: 20px;
        }
        .fi-blue   { background: #eff6ff; color: var(--blue); }
        .fi-gold   { background: #fffbeb; color: var(--gold); }
        .fi-green  { background: #ecfdf5; color: var(--green); }
        .fi-purple { background: #f5f3ff; color: var(--purple); }
        .fi-teal   { background: #f0fdfa; color: var(--teal); }
        .fi-rose   { background: #fff1f2; color: var(--rose); }
        .feat-card__title {
            font-size: 1.0625rem; font-weight: 700; color: var(--navy);
            margin-bottom: 10px;
        }
        .feat-card__desc {
            font-size: .875rem; color: var(--gray-500); line-height: 1.7;
            margin-bottom: 20px;
        }
        .feat-card__tags { display: flex; flex-wrap: wrap; gap: 6px; }
        .f-tag {
            font-size: .72rem; font-weight: 600; padding: 3px 10px;
            border-radius: 99px; background: var(--gray-100); color: var(--gray-500);
        }

        /* Featured large card */
        .feat-card.fc-large {
            grid-column: span 2;
            display: grid; grid-template-columns: 1fr 1fr; gap: 32px;
            align-items: center;
        }
        .feat-large__visual {
            background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
            border-radius: 12px; padding: 20px;
            min-height: 160px; display: flex; flex-direction: column; gap: 8px;
        }
        .flv-row { display: flex; gap: 8px; }
        .flv-card {
            flex: 1; background: rgba(255,255,255,.07); border-radius: 8px;
            padding: 10px; border: 1px solid rgba(255,255,255,.1);
        }
        .flv-num { font-size: 1.1rem; font-weight: 800; color: var(--gold-l); }
        .flv-lbl { height: 5px; border-radius: 3px; background: rgba(255,255,255,.15); width: 60%; margin-top: 4px; }
        .flv-bar { background: rgba(255,255,255,.07); border-radius: 8px; padding: 10px; border: 1px solid rgba(255,255,255,.1); }
        .flv-bars { display: flex; gap: 5px; align-items: flex-end; height: 50px; margin-top: 6px; }
        .flv-b { flex: 1; border-radius: 3px 3px 0 0; background: linear-gradient(to top, var(--blue), var(--blue-ll)); }

        /* ══════════════ HOW IT WORKS ══════════════ */
        .how { padding: 100px 48px; background: var(--gray-50); }
        .how__inner { max-width: 1100px; margin: 0 auto; }
        .how__header { text-align: center; margin-bottom: 64px; }
        .how__steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; position: relative; }
        .how__steps::before {
            content: '';
            position: absolute; top: 40px; left: calc(16.67% + 40px); right: calc(16.67% + 40px);
            height: 2px; background: linear-gradient(90deg, var(--blue), var(--purple));
        }
        .how-step { text-align: center; padding: 0 16px; }
        .how-step__num {
            width: 80px; height: 80px; border-radius: 50%;
            background: linear-gradient(135deg, var(--blue) 0%, var(--purple) 100%);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.75rem; font-weight: 900; color: #fff;
            margin: 0 auto 24px; position: relative; z-index: 1;
            box-shadow: 0 8px 24px rgba(37,99,235,.35);
        }
        .how-step__title { font-size: 1.125rem; font-weight: 700; color: var(--navy); margin-bottom: 10px; }
        .how-step__desc { font-size: .875rem; color: var(--gray-500); line-height: 1.7; }

        /* ══════════════ SOLUTIONS ══════════════ */
        .solutions { padding: 100px 48px; background: #fff; }
        .solutions__inner { max-width: 1200px; margin: 0 auto; }
        .solutions__header { text-align: center; margin-bottom: 60px; }
        .solutions__header .section-sub { margin: 0 auto; }
        .sol-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
        .sol-card {
            border-radius: 24px; overflow: hidden;
            border: 1px solid var(--gray-100);
            transition: transform .25s, box-shadow .25s;
            display: flex; flex-direction: column;
        }
        .sol-card:hover { transform: translateY(-8px); box-shadow: 0 24px 64px rgba(0,0,0,.12); }
        .sol-card__img {
            height: 220px; position: relative; overflow: hidden;
            display: flex; align-items: center; justify-content: center;
        }
        .sol-img-school  { background: linear-gradient(145deg, #0f1c2e 0%, #1a3560 60%, #2563eb 100%); }
        .sol-img-teacher { background: linear-gradient(145deg, #064e3b 0%, #065f46 60%, #10b981 100%); }
        .sol-img-parent  { background: linear-gradient(145deg, #3b0764 0%, #6d28d9 60%, #8b5cf6 100%); }
        .sol-card__emoji { font-size: 5rem; filter: drop-shadow(0 4px 20px rgba(0,0,0,.3)); }
        .sol-card__tag {
            position: absolute; top: 14px; left: 14px;
            font-size: .72rem; font-weight: 700; letter-spacing: .5px; text-transform: uppercase;
            color: #fff; background: rgba(255,255,255,.15);
            backdrop-filter: blur(8px); padding: 4px 12px; border-radius: 99px;
            border: 1px solid rgba(255,255,255,.25);
        }
        .sol-card__body { padding: 24px; background: #fff; flex: 1; display: flex; flex-direction: column; }
        .sol-card__title { font-size: 1.125rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
        .sol-card__desc { font-size: .875rem; color: var(--gray-500); line-height: 1.7; flex: 1; margin-bottom: 18px; }
        .sol-link {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: .875rem; font-weight: 600; color: var(--blue);
            text-decoration: none; transition: gap .15s;
        }
        .sol-link:hover { gap: 10px; }

        /* ══════════════ TESTIMONIALS ══════════════ */
        .testi { padding: 100px 48px; background: var(--gray-50); }
        .testi__inner { max-width: 1100px; margin: 0 auto; }
        .testi__header { text-align: center; margin-bottom: 56px; }
        .testi__header .section-sub { margin: 0 auto; }
        .testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
        .testi-card {
            background: #fff; border-radius: 20px; padding: 28px;
            border: 1px solid var(--gray-100);
            transition: transform .25s, box-shadow .25s;
        }
        .testi-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,.08); }
        .testi-stars { display: flex; gap: 3px; color: var(--gold); font-size: .9rem; margin-bottom: 16px; }
        .testi-text {
            font-size: .9375rem; color: var(--gray-600); line-height: 1.75;
            margin-bottom: 20px; font-style: italic;
        }
        .testi-author { display: flex; align-items: center; gap: 12px; }
        .testi-avatar {
            width: 42px; height: 42px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; font-weight: 700; color: #fff; flex-shrink: 0;
        }
        .testi-name { font-size: .875rem; font-weight: 700; color: var(--navy); }
        .testi-role { font-size: .78rem; color: var(--gray-400); }

        /* ══════════════ CTA BANNER ══════════════ */
        .cta-banner {
            padding: 80px 48px;
            background: linear-gradient(135deg, var(--navy) 0%, #1e3a5f 50%, var(--navy-3) 100%);
            position: relative; overflow: hidden;
        }
        .cta-banner::before {
            content: ''; position: absolute; inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
            background-size: 48px 48px;
        }
        .cta-banner__inner {
            position: relative; z-index: 1;
            max-width: 700px; margin: 0 auto; text-align: center;
        }
        .cta-banner__title {
            font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 900;
            color: #fff; letter-spacing: -.5px; margin-bottom: 16px; line-height: 1.2;
        }
        .cta-banner__title span { color: var(--gold-l); }
        .cta-banner__sub { font-size: 1rem; color: rgba(255,255,255,.6); line-height: 1.7; margin-bottom: 36px; }
        .cta-banner__btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
        .btn-cta-gold {
            font-size: .9375rem; font-weight: 700; color: var(--navy);
            background: var(--gold); text-decoration: none;
            padding: 14px 32px; border-radius: 10px;
            box-shadow: 0 4px 20px rgba(245,158,11,.4);
            transition: all .2s; display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-cta-gold:hover { background: var(--gold-l); transform: translateY(-2px); }
        .btn-cta-outline {
            font-size: .9375rem; font-weight: 600; color: rgba(255,255,255,.85);
            text-decoration: none; padding: 14px 28px; border-radius: 10px;
            border: 1px solid rgba(255,255,255,.25);
            transition: all .2s; display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-cta-outline:hover { color: #fff; border-color: rgba(255,255,255,.6); background: rgba(255,255,255,.08); }

        /* ══════════════ FOOTER ══════════════ */
        .footer { background: var(--navy); padding: 64px 48px 32px; }
        .footer__inner { max-width: 1200px; margin: 0 auto; }
        .footer__top {
            display: grid; grid-template-columns: 2.5fr 1fr 1fr 1fr; gap: 48px;
            padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,.08);
            margin-bottom: 28px;
        }
        .footer__logo {
            font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 800;
            color: var(--gold); display: flex; align-items: center; gap: 8px;
            margin-bottom: 16px; text-decoration: none;
        }
        .footer__desc { font-size: .875rem; color: rgba(255,255,255,.4); line-height: 1.7; max-width: 280px; margin-bottom: 24px; }
        .footer__social { display: flex; gap: 8px; }
        .footer__soc-btn {
            width: 36px; height: 36px; border-radius: 8px;
            border: 1px solid rgba(255,255,255,.12); color: rgba(255,255,255,.4);
            display: flex; align-items: center; justify-content: center;
            text-decoration: none; font-size: .9rem;
            transition: all .2s;
        }
        .footer__soc-btn:hover { border-color: var(--gold); color: var(--gold); }
        .footer__col-title { font-size: .72rem; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: rgba(255,255,255,.3); margin-bottom: 16px; }
        .footer__col-link {
            display: block; font-size: .875rem; color: rgba(255,255,255,.5);
            text-decoration: none; margin-bottom: 10px; transition: color .15s;
        }
        .footer__col-link:hover { color: var(--gold); }
        .footer__bottom { display: flex; justify-content: space-between; align-items: center; }
        .footer__copy { font-size: .8rem; color: rgba(255,255,255,.3); }
        .footer__badge {
            font-size: .75rem; color: rgba(255,255,255,.3); display: flex; align-items: center; gap: 6px;
        }
        .footer__badge i { color: var(--gold); }

        /* ══════════════ RESPONSIVE ══════════════ */
        @@media (max-width: 1024px) {
            .nav { padding: 0 24px; }
            .nav__links { display: none; }
            .hero { padding: 100px 24px 60px; }
            .stats-bar__inner { grid-template-columns: repeat(2, 1fr); gap: 24px; }
            .stat-item { border-right: none; }
            .features, .how, .solutions, .testi, .cta-banner { padding: 72px 24px; }
            .features__header { grid-template-columns: 1fr; gap: 16px; }
            .features__right { text-align: left; }
            .features__grid { grid-template-columns: repeat(2, 1fr); }
            .feat-card.fc-large { grid-column: span 2; }
            .how__steps { grid-template-columns: 1fr; }
            .how__steps::before { display: none; }
            .sol-grid, .testi-grid { grid-template-columns: repeat(2, 1fr); }
            .screen__body { grid-template-columns: 1fr; }
            .screen__sidebar { display: none; }
            .footer { padding: 48px 24px 24px; }
            .footer__top { grid-template-columns: 1fr 1fr; gap: 32px; }
        }
        @@media (max-width: 640px) {
            .hero__title { font-size: 2rem; }
            .stats-bar { padding: 32px 20px; }
            .stats-bar__inner { grid-template-columns: repeat(2, 1fr); }
            .features__grid { grid-template-columns: 1fr; }
            .feat-card.fc-large { grid-column: span 1; }
            .feat-card.fc-large { display: block; }
            .sol-grid, .testi-grid { grid-template-columns: 1fr; }
            .footer__top { grid-template-columns: 1fr; gap: 24px; }
            .footer__bottom { flex-direction: column; gap: 8px; text-align: center; }
        }

        /* Scroll animation */
        .reveal { opacity: 0; transform: translateY(28px); transition: opacity .6s ease, transform .6s ease; }
        .reveal.visible { opacity: 1; transform: none; }
        .reveal-delay-1 { transition-delay: .1s; }
        .reveal-delay-2 { transition-delay: .2s; }
        .reveal-delay-3 { transition-delay: .3s; }
    </style>
</head>
<body>

