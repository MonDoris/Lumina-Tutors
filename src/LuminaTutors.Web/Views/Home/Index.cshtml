<!-- ══════════════════════════ FEATURES ══════════════════════════ -->
<section class="features" id="features" data-testid="features-section">
    <div class="features__inner">
        <div class="features__header">
            <div>
                <div class="section-badge reveal"><i class="bi bi-grid-3x3-gap-fill"></i> Tính năng</div>
                <h2 class="section-title reveal">Mọi thứ bạn cần trong<br/>một nền tảng duy nhất</h2>
                <p class="section-sub reveal">Hơn 50 tính năng được xây dựng chuyên biệt cho hệ sinh thái giáo dục Việt Nam.</p>
            </div>
            <div class="features__right reveal">
                <a href="#solutions" class="btn-outline-blue">Xem tất cả tính năng <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>

