// ── Data panel ────────────────────────────────────────────────────────────────

function initDataPanel() {
    if (!DATA_PANEL_SCENES.has(SCENE_TYPE)) return;
    dataPanel.classList.add('show');
    updateDataPanel();
}

function updateDataPanel() {
    if (SCENE_TYPE === 'electrolysis') {
        const t   = (experimentData.powerTimer || 0).toFixed(1);
        const h2  = (experimentData.powerTimer * 0.0037).toFixed(3);
        const o2  = (experimentData.powerTimer * 0.00185).toFixed(3);
        dpRows.innerHTML = `
            <div class="dp-row"><span class="dp-label">Trạng thái mạch</span>
              <span class="dp-value" style="color:${experimentData.powered?'#4ade80':'#64748b'}">${experimentData.powered?'Đóng':'Mở'}</span></div>
            <div class="dp-row"><span class="dp-label">Thời gian (t)</span>
              <span class="dp-value">${t}<span class="dp-unit">s</span></span></div>
            <div class="dp-row"><span class="dp-label">Khí H₂ (catod)</span>
              <span class="dp-value">${h2}<span class="dp-unit">mL</span></span></div>
            <div class="dp-row"><span class="dp-label">Khí O₂ (anod)</span>
              <span class="dp-value">${o2}<span class="dp-unit">mL</span></span></div>`;
    } else if (SCENE_TYPE === 'distillation') {
        const T = (experimentData.temp || 20).toFixed(1);
        const collected = Math.min(100, (experimentData.heatTime || 0) * 2).toFixed(0);
        dpRows.innerHTML = `
            <div class="dp-row"><span class="dp-label">Nhiệt độ (T)</span>
              <span class="dp-value" style="color:${T>77?'#ef4444':'#e2e8f0'}">${T}<span class="dp-unit">°C</span></span></div>
            <div class="dp-row"><span class="dp-label">Trạng thái đun</span>
              <span class="dp-value" style="color:${experimentData.heating?'#f97316':'#64748b'}">${experimentData.heating?'Đang đun':'Tắt'}</span></div>
            <div class="dp-row"><span class="dp-label">Đã thu được</span>
              <span class="dp-value">${collected}<span class="dp-unit">%</span></span></div>`;
    } else if (SCENE_TYPE === 'spring') {
        const k   = experimentData.springK;
        const m   = experimentData.springM;
        const T   = (2 * Math.PI * Math.sqrt(m / k)).toFixed(3);
        const x   = (experimentData.springDisp * 100).toFixed(1);
        const v   = Math.abs((experimentData.springVel || 0) * 100).toFixed(2);
        const E   = (.5 * k * experimentData.springDisp ** 2).toFixed(4);
        dpRows.innerHTML = `
            <div class="dp-row"><span class="dp-label">k = hệ số lò xo</span>
              <span class="dp-value">${k}<span class="dp-unit">N/m</span></span></div>
            <div class="dp-row"><span class="dp-label">Ly độ x</span>
              <span class="dp-value">${x}<span class="dp-unit">cm</span></span></div>
            <div class="dp-row"><span class="dp-label">Chu kỳ lý thuyết</span>
              <span class="dp-value">${T}<span class="dp-unit">s</span></span></div>
            <div class="dp-row"><span class="dp-label">Thế năng đàn hồi</span>
              <span class="dp-value">${E}<span class="dp-unit">J</span></span></div>`;
    } else if (SCENE_TYPE === 'polyhedron') {
        const idx = experimentData.polyIndex ?? 0;
        const s   = experimentData.polySolids?.[idx];
        if (s) {
            const euler = s.V - s.E + s.F;
            dpRows.innerHTML = `
                <div class="dp-row"><span class="dp-label">Tên</span>
                  <span class="dp-value" style="font-size:.75rem">${s.name.split('(')[0].trim()}</span></div>
                <div class="dp-row"><span class="dp-label">Đỉnh V</span>
                  <span class="dp-value">${s.V}</span></div>
                <div class="dp-row"><span class="dp-label">Cạnh E</span>
                  <span class="dp-value">${s.E}</span></div>
                <div class="dp-row"><span class="dp-label">Mặt F</span>
                  <span class="dp-value">${s.F}</span></div>
                <div class="dp-row"><span class="dp-label">V−E+F (Euler)</span>
                  <span class="dp-value" style="color:#4ade80">${euler}</span></div>`;
        }
    } else if (SCENE_TYPE === 'vectors') {
        const O  = experimentData.vecO;
        const uE = experimentData.vecU?.end;
        const vE = experimentData.vecV?.end;
        if (uE && vE && O) {
            const u  = uE.clone().sub(O);
            const v  = vE.clone().sub(O);
            const dot  = u.dot(v).toFixed(3);
            const cosT = (u.dot(v) / (u.length() * v.length()));
            const ang  = (Math.acos(THREE.MathUtils.clamp(cosT,-1,1)) * 180 / Math.PI).toFixed(1);
            const cross = new THREE.Vector3().crossVectors(u, v);
            dpRows.innerHTML = `
                <div class="dp-row"><span class="dp-label">|u⃗|</span>
                  <span class="dp-value">${u.length().toFixed(3)}</span></div>
                <div class="dp-row"><span class="dp-label">|v⃗|</span>
                  <span class="dp-value">${v.length().toFixed(3)}</span></div>
                <div class="dp-row"><span class="dp-label">u⃗·v⃗ (tích vô hướng)</span>
                  <span class="dp-value">${dot}</span></div>
                <div class="dp-row"><span class="dp-label">Góc (θ)</span>
                  <span class="dp-value">${ang}<span class="dp-unit">°</span></span></div>
                <div class="dp-row"><span class="dp-label">|u⃗×v⃗|</span>
                  <span class="dp-value">${cross.length().toFixed(3)}</span></div>`;
        }
    } else if (SCENE_TYPE === 'titration') {
        const dropped = experimentData.dripCount * 0.05;
        const vol     = Math.max(0, experimentData.buretVolume - dropped).toFixed(2);
        const dripR   = experimentData.dripRate;
        const badge   = `<span class="drip-badge ${dripR}">${
            dripR === 'off' ? 'Tắt' : dripR === 'slow' ? 'Chậm' : 'Nhanh'
        }</span>`;
        dpRows.innerHTML = `
            <div class="dp-row">
                <span class="dp-label">Tốc độ nhỏ giọt</span>
                <span>${badge}</span>
            </div>
            <div class="dp-row">
                <span class="dp-label">Thể tích đã nhỏ</span>
                <span class="dp-value">${dropped.toFixed(2)}<span class="dp-unit">mL</span></span>
            </div>
            <div class="dp-row">
                <span class="dp-label">Buret còn lại</span>
                <span class="dp-value">${vol}<span class="dp-unit">mL</span></span>
            </div>
            <div class="dp-row">
                <span class="dp-label">Số giọt</span>
                <span class="dp-value">${experimentData.dripCount}</span>
            </div>
        `;
    } else if (SCENE_TYPE === 'pendulum') {
        const L    = experimentData.stringLen;
        const g    = 9.81;
        const T    = 2 * Math.PI * Math.sqrt(L / g);
        const deg  = (experimentData.angle * 180 / Math.PI).toFixed(1);
        const v    = Math.abs(experimentData.vel * L).toFixed(3);
        const osc  = experimentData.oscCount ?? 0;
        const hint = isRunning ? '' : '<span style="font-size:.66rem;color:#334155;margin-left:4px">(cuộn để đổi)</span>';
        dpRows.innerHTML = `
            <div class="dp-row">
                <span class="dp-label">Chiều dài dây (L)${hint}</span>
                <span class="dp-value">${L.toFixed(2)}<span class="dp-unit">m</span></span>
            </div>
            <div class="dp-row">
                <span class="dp-label">Góc lệch (θ)</span>
                <span class="dp-value">${deg}<span class="dp-unit">°</span></span>
            </div>
            <div class="dp-row">
                <span class="dp-label">Chu kỳ lý thuyết</span>
                <span class="dp-value">${T.toFixed(3)}<span class="dp-unit">s</span></span>
            </div>
            <div class="dp-row">
                <span class="dp-label">Vận tốc tức thời</span>
                <span class="dp-value">${v}<span class="dp-unit">m/s</span></span>
            </div>
            <div class="dp-row">
                <span class="dp-label">Số dao động</span>
                <span class="dp-value">${osc}</span>
            </div>
        `;
    }
}

// ── Step HUD helpers ──────────────────────────────────────────────────────────
const stepOverlay  = document.getElementById('step-overlay');
const stepTitle    = document.getElementById('step-title');
const stepDesc     = document.getElementById('step-desc');
const stepNum      = document.getElementById('step-num');
const stepPct      = document.getElementById('step-pct');
const stepBarFill  = document.getElementById('step-bar-fill');

function showStep(idx) {
    const steps = experimentData.steps || [];
    if (!steps.length) return;
    idx = Math.min(idx, steps.length - 1);
    const s   = steps[idx];
    const pct = Math.round((idx+1) / steps.length * 100);
    stepOverlay.classList.add('show');
    stepTitle.textContent   = s.title;
    stepDesc.textContent    = s.desc;
    stepNum.textContent     = `Bước ${idx+1}/${steps.length}`;
    stepPct.textContent     = `${pct}%`;
    stepBarFill.style.width = `${pct}%`;
}

// ── Experiment controls ───────────────────────────────────────────────────────
window.startExperiment = function() {
    if (isRunning) {
        stepIndex = Math.min(stepIndex + 1, (experimentData.steps?.length || 1) - 1);
        showStep(stepIndex);
        return;
    }
    isRunning = true;
    stepIndex = 0;
    document.getElementById('btn-start').innerHTML = '<i class="bi bi-skip-forward-fill"></i> Bước tiếp';
    document.getElementById('btn-start').classList.add('active');
    showStep(0);
};

window.resetExperiment = function() {
    isRunning = false;
    stepIndex = 0;
    stepOverlay.classList.remove('show');
    document.getElementById('btn-start').innerHTML = '<i class="bi bi-play-fill"></i> Bắt đầu';
    document.getElementById('btn-start').classList.remove('active');

    if (experimentData.type === 'titration') {
        experimentData.solutionMat.color.set(0x93c5fd);
        experimentData.solutionMat.opacity = .55;
        experimentData.dripCount   = 0;
        experimentData.dripTimer   = 0;
        experimentData.buretVolume = 50.0;
        experimentData.dropletMat.opacity = 0;
        if (experimentData.streamMat) experimentData.streamMat.opacity = 0;
        experimentData.swirling   = false;
        experimentData.swirlAngle = 0;
        experimentData.flaskMeshes.forEach(m => { m.rotation.y = 0; });
        window.setDripRate('off'); // resets buttons + stopcock color + updateDataPanel
    }
    if (experimentData.type === 'pendulum') {
        experimentData.angle     = Math.PI / 6;
        experimentData.vel       = 0;
        experimentData.oscCount  = 0;
        experimentData.lastSign  = 0;
        // Reset string length to original
        experimentData.stringLen = experimentData.origStringLen ?? 1.4;
        if (experimentData.stringMesh) experimentData.stringMesh.scale.y = 1;
        updateDataPanel();
    }
    if (experimentData.type === 'cell') {
        closeCellInfo();
    }
    if (experimentData.type === 'electrolysis') {
        experimentData.powered     = false;
        experimentData.powerTimer  = 0;
        if (experimentData.switchLever) experimentData.switchLever.rotation.z = 0;
        if (experimentData.switchMat)   experimentData.switchMat.color.set(0x94a3b8);
        updateDataPanel();
    }
    if (experimentData.type === 'distillation') {
        experimentData.heating  = false;
        experimentData.heatTime = 0;
        experimentData.temp     = 20;
        if (experimentData.flameMat) { experimentData.flameMat.emissiveIntensity = 0; experimentData.flameMat.opacity = .15; }
        if (experimentData.colLiq)   experimentData.colLiq.scale.setScalar(.01);
        updateDataPanel();
    }
    if (experimentData.type === 'spring') {
        experimentData.springDisp = -0.2;
        experimentData.springVel  = 0;
        updateDataPanel();
    }
    if (experimentData.type === 'polyhedron') {
        experimentData.polyIndex = 0;
        experimentData.polyAngle = 0;
        experimentData.polyMeshes?.forEach((m, i) => { m.visible = i === 0; });
        experimentData.polyWires?.forEach((w, i)  => { w.visible = i === 0; });
        updateDataPanel();
    }
};

let orbitFree = false;
window.toggleOrbit = function() {
    orbitFree = !orbitFree;
    controls.autoRotate = orbitFree;
    document.getElementById('btn-orbit').classList.toggle('active', orbitFree);
};

window.focusCamera = function() {
    controls.autoRotate = false;
    orbitFree = false;
    document.getElementById('btn-orbit').classList.remove('active');
    const targetPos  = new THREE.Vector3(0, 4, 9);
    const targetLook = SCENE_TYPE === 'cell'
        ? new THREE.Vector3(0, 1.8, 0)
        : new THREE.Vector3(0, 1.2, 0);
    animCam = { pos: targetPos, look: targetLook, t: 0 };
};

let animCam = null;

// ── Clock ─────────────────────────────────────────────────────────────────────
const clock = new THREE.Clock();
let dataPanelTimer = 0;

// ── Render loop ───────────────────────────────────────────────────────────────
function animate() {
    requestAnimationFrame(animate);
    const dt  = clock.getDelta();
    const now = clock.getElapsedTime();

    controls.update();

    // Smooth camera animation
    if (animCam) {
        animCam.t += dt * 2.5;
        const t    = Math.min(animCam.t, 1);
        const ease = 1 - Math.pow(1 - t, 3);
        camera.position.lerp(animCam.pos,   ease * dt * 5);
        controls.target.lerp(animCam.look,  ease * dt * 5);
        if (t >= 1) animCam = null;
    }

    // ── Laser pointer update ─────────────────────────────────────────────────
    if (laserMode) {
        raycaster.setFromCamera(mouse, camera);
        const hits = raycaster.intersectObjects(laserTargets, false);
        if (hits.length > 0) {
            laserDot.visible = true;
            laserDot.position.copy(hits[0].point).addScaledVector(hits[0].face.normal, 0.02);
            laserDot.material.emissiveIntensity = 1.2 + Math.sin(now * 12) * 0.4;
        } else {
            laserDot.visible = false;
        }
    }

    // ── Titration animation ──────────────────────────────────────────────────
    if (SCENE_TYPE === 'titration') {
        const progress = stepIndex / Math.max(1, (experimentData.steps?.length || 1) - 1);

        // Drip logic
        if (experimentData.dripRate !== 'off') {
            const interval = experimentData.dripRate === 'slow' ? 1.5 : 0.42;
            experimentData.dripTimer += dt;
            if (experimentData.dripTimer >= interval) {
                experimentData.dripTimer = 0;
                experimentData.dripCount++;
                experimentData.buretVolume = Math.max(0, experimentData.buretVolume - 0.05);
            }
        }

        // Droplet + stream visual
        const d   = experimentData.droplet;
        const dm  = experimentData.dropletMat;
        const sm  = experimentData.streamMesh;
        const smM = experimentData.streamMat;
        if (experimentData.dripRate === 'slow') {
            const interval = 1.5;
            const phase    = experimentData.dripTimer / interval;
            // Droplet swells, detaches, falls
            dm.opacity   = Math.pow(Math.sin(phase * Math.PI), 1.2) * 0.88;
            d.position.y = experimentData.dropletY - phase * 0.38;
            d.visible    = true;
            // No stream in slow mode
            if (smM) smM.opacity = 0;
        } else if (experimentData.dripRate === 'fast') {
            // Continuous stream visible, droplet falls fast
            const interval = 0.42;
            const phase    = experimentData.dripTimer / interval;
            dm.opacity     = Math.pow(Math.sin(phase * Math.PI), 1.0) * 0.7;
            d.position.y   = experimentData.dropletY - phase * 0.4;
            d.visible      = true;
            // Show stream
            if (smM) {
                smM.opacity = 0.55 + Math.sin(now * 18) * 0.1; // shimmer
                sm.visible  = true;
            }
        } else {
            dm.opacity  = 0;
            d.visible   = false;
            if (smM) smM.opacity = 0;
        }

        // Solution color shift: clear blue → pink at equivalence
        if (isRunning && progress > .4) {
            const pink = Math.min(1, (progress - .4) * 1.8);
            experimentData.solutionMat.color.setRGB(
                .58 + pink * .38,
                .76 - pink * .36,
                .99 - pink * .6
            );
            experimentData.solutionMat.opacity = .55 + pink * .2;
        }

        // Stopcock hint rotation when running
        if (isRunning && stepIndex >= 1 && experimentData.dripRate === 'off') {
            experimentData.stopcock.rotation.y = Math.sin(now * 2) * .15;
        }

        // Flask swirl animation
        if (experimentData.swirling) {
            experimentData.swirlTime  += dt;
            experimentData.swirlAngle += dt * 8;
            const t = experimentData.swirlTime / 1.2;
            const decay = Math.max(0, 1 - t);
            experimentData.flaskMeshes.forEach(m => {
                m.rotation.y = Math.sin(experimentData.swirlAngle) * decay * 0.18;
            });
            if (t >= 1) {
                experimentData.swirling = false;
                experimentData.flaskMeshes.forEach(m => { m.rotation.y = 0; });
            }
        }

        // Data panel throttle
        dataPanelTimer += dt;
        if (dataPanelTimer > 0.25) { dataPanelTimer = 0; updateDataPanel(); }
    }

    // ── Pendulum animation ───────────────────────────────────────────────────
    if (SCENE_TYPE === 'pendulum') {
        if (!dragActive) {
            const L = experimentData.stringLen;
            const g = 9.81;
            if (isRunning) {
                const acc = -(g / L) * Math.sin(experimentData.angle);
                experimentData.vel   += acc * dt;
                experimentData.vel   *= experimentData.damping;
                experimentData.angle += experimentData.vel * dt;

                // Count oscillations (zero crossings from positive side)
                const sign = Math.sign(experimentData.angle);
                if (experimentData.lastSign === 1 && sign === -1) experimentData.oscCount++;
                experimentData.lastSign = sign;
            }
        }

        const a  = experimentData.angle;
        const L  = experimentData.stringLen;
        const px = Math.sin(a) * L;
        const py = -Math.cos(a) * L;

        const bob = experimentData.bob;
        bob.position.set(px, experimentData.pivotY + py, 0);
        // Keep invisible hit sphere in sync with the visual bob
        if (experimentData.hitSphere) experimentData.hitSphere.position.copy(bob.position);

        const sm = experimentData.stringMesh;
        sm.position.set(px / 2, experimentData.pivotY + py / 2, 0);
        sm.rotation.z = -a;

        // Trail
        const tp = experimentData.trailPts;
        const ti = experimentData.trailIdx;
        tp[ti*3]   = px; tp[ti*3+1] = experimentData.pivotY + py; tp[ti*3+2] = 0;
        experimentData.trailIdx = (ti + 1) % 20;
        experimentData.trail.geometry.attributes.position.needsUpdate = true;

        // Bob glow when dragging
        if (dragActive) {
            experimentData.bobMat.emissive          = new THREE.Color(0xc9a96e);
            experimentData.bobMat.emissiveIntensity  = 0.5;
        } else {
            experimentData.bobMat.emissiveIntensity = 0;
        }

        // Data panel
        dataPanelTimer += dt;
        if (dataPanelTimer > 0.08) { dataPanelTimer = 0; updateDataPanel(); }
    }

    // ── Cell animation ───────────────────────────────────────────────────────
    if (SCENE_TYPE === 'cell') {
        experimentData.cellAngle += dt * .4;
        const ca = experimentData.cellAngle;

        const s = 1 + Math.sin(now * .6) * .025;
        experimentData.cell.scale.set(s, s, s);

        (experimentData.mito || []).forEach((m, i) => {
            const a = ca + m.baseAngle;
            m.mesh.position.set(
                Math.sin(a) * m.r,
                1.8 + Math.sin(a * 1.3 + i) * .15,
                Math.cos(a) * m.r
            );
            m.mesh.rotation.z = a + .4;
        });
    }

    // ── Electrolysis animation ───────────────────────────────────────────────
    if (SCENE_TYPE === 'electrolysis') {
        if (experimentData.powered) {
            experimentData.powerTimer = (experimentData.powerTimer || 0) + dt;
        }
        (experimentData.bubbles || []).forEach(b => {
            if (!experimentData.powered) { b.mat.opacity = 0; return; }
            b.userData.age += dt * b.userData.spd * 10;
            if (b.userData.age > 1) {
                b.userData.age = 0;
                b.mesh.position.set(b.userData.side + b.userData.rx, 1.02, -.1 + (Math.random()-.5)*.06);
                b.userData.rx = (Math.random()-.5) * .06;
            }
            b.mesh.position.y += dt * .12;
            b.mat.opacity = Math.sin(b.userData.age * Math.PI) * .85;
        });
        dataPanelTimer += dt;
        if (dataPanelTimer > .5) { dataPanelTimer = 0; updateDataPanel(); }
    }

    // ── Distillation animation ───────────────────────────────────────────────
    if (SCENE_TYPE === 'distillation') {
        if (experimentData.heating) {
            experimentData.heatTime = (experimentData.heatTime || 0) + dt;
            experimentData.temp = Math.min(82, 20 + experimentData.heatTime * 8);
            // Flame flicker
            experimentData.flame.scale.y = 0.9 + Math.sin(now * 18) * .15;
            // Collection liquid grows
            const scale = Math.min(1, experimentData.heatTime * .05);
            if (experimentData.colLiq) experimentData.colLiq.scale.setScalar(Math.max(.01, scale));
            if (experimentData.colLiqMat) experimentData.colLiqMat.opacity = .4 + scale * .3;
        }
        dataPanelTimer += dt;
        if (dataPanelTimer > .5) { dataPanelTimer = 0; updateDataPanel(); }
    }

    // ── Spring animation ─────────────────────────────────────────────────────
    if (SCENE_TYPE === 'spring') {
        if (!dragActive) {
            if (isRunning) {
                const k   = experimentData.springK;
                const m   = experimentData.springM;
                const acc = -(k / m) * experimentData.springDisp;
                experimentData.springVel  += acc * dt;
                experimentData.springVel  *= experimentData.springDamping;
                experimentData.springDisp += experimentData.springVel * dt;
            }
        }
        const topY  = experimentData.springTopY;
        const natL  = experimentData.springNatural;
        const disp  = experimentData.springDisp;
        const blockY = topY - natL - .075 + disp;
        experimentData.block.position.y = blockY;
        if (experimentData.springHit) experimentData.springHit.position.y = blockY;

        // Update spring coil positions to match extension
        const nCoils = experimentData.springCoils?.length ?? 0;
        const stretch = natL + disp;
        (experimentData.springCoils || []).forEach((coil, i) => {
            coil.position.y = topY - (i / (nCoils-1)) * stretch;
        });

        dataPanelTimer += dt;
        if (dataPanelTimer > .06) { dataPanelTimer = 0; updateDataPanel(); }
    }

    // ── Optics animation ─────────────────────────────────────────────────────
    if (SCENE_TYPE === 'optics') {
        // Gentle rotation hint
        if (experimentData.prism) {
            experimentData.prism.rotation.y += dt * .3;
            // Rainbow rays flutter slightly
            (experimentData.outRays || []).forEach((r, i) => {
                r.material.emissiveIntensity = 1.2 + Math.sin(now * 3 + i) * .4;
            });
        }
    }

    // ── DNA animation ────────────────────────────────────────────────────────
    if (SCENE_TYPE === 'dna') {
        experimentData.dnaAngle = (experimentData.dnaAngle || 0) + dt * .5;
        if (experimentData.dnaTube1) {
            experimentData.dnaTube1.rotation.y = experimentData.dnaAngle;
            experimentData.dnaTube2.rotation.y = experimentData.dnaAngle;
        }
        (experimentData.dnaBasePairs || []).forEach((bp, i) => {
            bp.b1.rotation.y = experimentData.dnaAngle;
            bp.b2.rotation.y = experimentData.dnaAngle;
        });
    }

    // ── Photosynthesis animation ─────────────────────────────────────────────
    if (SCENE_TYPE === 'photosynthesis') {
        experimentData.psAngle = (experimentData.psAngle || 0) + dt;
        // Sun rays pulse
        (experimentData.sunRays || []).forEach((r, i) => {
            r.mat.opacity = .4 + Math.sin(experimentData.psAngle * 2 + i) * .2;
        });
        // CO2 molecules drift toward leaf
        (experimentData.co2Meshes || []).forEach(c => {
            if (!c.mesh.userData.done) {
                c.mesh.position.x += (c.mesh.userData.targetX - c.mesh.position.x) * dt * .4;
                if (Math.abs(c.mesh.position.x - c.mesh.userData.targetX) < .05) {
                    c.mesh.userData.done = true;
                    c.mat.opacity = 0;
                }
            }
        });
        // O2 bubbles rise
        (experimentData.o2Meshes || []).forEach((o, i) => {
            o.mesh.position.y += dt * .08;
            const relY = o.mesh.position.y - o.mesh.userData.startY;
            o.mat.opacity = Math.max(0, .8 - relY * 1.2);
            if (o.mesh.position.y > 2.5) {
                o.mesh.position.y = o.mesh.userData.startY;
                o.mat.opacity     = 0;
            }
        });
        // Chloroplasts breathe
        (experimentData.cpMeshes || []).forEach((c, i) => {
            const s = 1 + Math.sin(experimentData.psAngle * 1.5 + i) * .05;
            c.mesh.scale.set(s, s, s);
        });
    }

    // ── Polyhedron animation ─────────────────────────────────────────────────
    if (SCENE_TYPE === 'polyhedron') {
        experimentData.polyAngle = (experimentData.polyAngle || 0) + dt * .6;
        const idx = experimentData.polyIndex ?? 0;
        const m   = experimentData.polyMeshes?.[idx];
        const w   = experimentData.polyWires?.[idx];
        if (m) { m.rotation.x = experimentData.polyAngle * .5; m.rotation.y = experimentData.polyAngle; }
        if (w) { w.rotation.copy(m.rotation); }
    }

    // ── Vectors animation ────────────────────────────────────────────────────
    if (SCENE_TYPE === 'vectors') {
        experimentData.vecAngle = (experimentData.vecAngle || 0) + dt * .5;
        // Slow auto-rotate vectors for visual exploration
        const a  = experimentData.vecAngle;
        const O  = experimentData.vecO;
        dataPanelTimer += dt;
        if (dataPanelTimer > .3) { dataPanelTimer = 0; updateDataPanel(); }
    }

    // Rim light pulse
    rimLight.intensity = .5 + Math.sin(now * .8) * .15;

    renderer.render(scene, camera);
}
animate();

// ── Hide loading screen after first rendered frame ────────────────────────────
// Calls the plain-script bridge so the overlay is dismissed correctly.
// The bridge also has its own hard timeout as a backstop.
function hideLoading() {
    if (typeof window.__labLoadingDone === 'function') {
        window.__labLoadingDone();
        window.__labLoadingDone = null;
    }
}
// Fire after the second animation frame — by then the first pixel is on screen
requestAnimationFrame(() => requestAnimationFrame(hideLoading));

// ── Resize ────────────────────────────────────────────────────────────────────
window.addEventListener('resize', () => {
    const w = window.innerWidth, h = window.innerHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
});

// ── Expose helpers to onclick attributes ─────────────────────────────────────
window.closeCellInfo = window.closeCellInfo || (() => {});

</script>

</body>
