function showCellInfo(key, pos) {
    const info = CELL_INFO[key];
    if (!info) return;

    document.getElementById('cic-icon').textContent  = info.icon;
    document.getElementById('cic-title').textContent = info.title;
    document.getElementById('cic-desc').textContent  = info.desc;
